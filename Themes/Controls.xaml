    <!-- === Base TextBlock === -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <!-- === Icon TextBlock helper === -->
    <Style x:Key="Icon" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource IconFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- === Primary Button === -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="MinWidth" Value="110" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentPressed}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- === Secondary (ghost) Button === -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="Background" Value="{DynamicResource BgElevated}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="MinWidth" Value="90" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgSurface}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- === Danger Button === -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Foreground" Value="{DynamicResource Danger}" />
    </Style>

    <!-- === Title Bar Icon Button === -->
    <Style x:Key="TitleBarButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="32" />
        <Setter Property="FontFamily" Value="{DynamicResource IconFont}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#E81123" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- === TextBox === -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource BgSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Accent}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Accent}" />
        <Setter Property="SelectionOpacity" Value="0.35" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      Background="Transparent"
                                      Foreground="{TemplateBinding Foreground}"
                                      VerticalAlignment="Stretch" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- === CheckBox (toggle-ish) === -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="Track"
                                Width="36" Height="20"
                                CornerRadius="10"
                                Background="{DynamicResource BgHover}"
                                BorderBrush="{DynamicResource Border}"
                                BorderThickness="1">
                            <Ellipse x:Name="Thumb"
                                     Width="14" Height="14"
                                     Fill="{DynamicResource TextSecondary}"
                                     HorizontalAlignment="Left"
                                     Margin="3,0,0,0" />
                        </Border>
                        <ContentPresenter Margin="10,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource Accent}" />
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            <Setter TargetName="Thumb" Property="Fill" Value="White" />
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- === Sidebar nav item (icon-only, centered) ===
         Narrow rail design: no active accent bar, no left margin.
         Selected state = soft accent background.
         Hover state    = subtle surface lift. -->
    <Style x:Key="NavListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="6,3" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            CornerRadius="10"
                            Height="40"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavHoverBg}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavSelectedBg}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- === Card panel === -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BgSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- === Subtle card with vertical gradient (used for hero areas) === -->
    <Style x:Key="GlowCard" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="Background" Value="{DynamicResource CardGlow}" />
    </Style>

    <!-- === Icon-only round button (e.g. collapse / expand toggles) === -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{DynamicResource IconFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- === Segmented control button (pill in a row), used for the theme picker === -->
    <Style x:Key="SegmentButton" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="7"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgSurface}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- === Sidebar footer dot (collapsed sidebar shows a simple dot with a ring) === -->
    <Style x:Key="SidebarFooterDot" TargetType="Border">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Background" Value="{DynamicResource BgHover}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- === Badge === -->
    <Style x:Key="Badge" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BgHover}" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <!-- === ListBox for received texts (flat) === -->
    <Style x:Key="FlatListBox" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
    </Style>

    <Style x:Key="FlatListBoxItem" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border Background="Transparent" Padding="0">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- === ScrollBar (thin modern) === -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource BorderStrong}" />
        <Setter Property="Width" Value="10" />
        <Setter Property="MinWidth" Value="10" />
    </Style>

    <!-- === Voice-page language picker ComboBox ====================
        Premium-feeling combo inspired by Raycast/Linear/MicTab:
          • 16px rounded corners on both pill and popup
          • White surface (BgSurface), subtle border, soft shadow
          • Items have ~44px height, hover = light gray, selected =
            soft purple + accent checkmark
          • Uses an explicit ItemTemplate that binds to the Label
            property of LangOption, so the selection display shows
            the same "🇧🇩 Bengali (BD)" string as the dropdown rows
            (the default WPF behaviour falls back to ToString() on
            record types, which leaks "LangOption { Code=…, Label=… }")
    -->

    <!-- DataTemplate used for BOTH dropdown rows and the selected pill.
         Premium-feeling layout (Raycast / MicTab style):
           • 20×14 flag with proper aspect ratio (no stretching)
           • 3px rounded corners, soft border for definition
           • 10px gap to language label
           • 15px Medium-weight Segoe UI text for clear hierarchy
           • If the LangOption has no flag asset, a small soft-purple
             pill with the 2-letter country code is shown instead. -->
    <DataTemplate x:Key="VoiceLangItemTemplate">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

            <!-- Flag area: 20×14 (≈ 10:7, close to the 3:2 most flags use) -->
            <Grid Width="20" Height="14" VerticalAlignment="Center"
                  SnapsToDevicePixels="True">

                <!-- Fallback: rounded soft-purple pill with the 2-letter
                     country code. Visible by default; the Image on top
                     hides it whenever a real PNG is available. -->
                <Border x:Name="FlagFallback"
                        CornerRadius="3"
                        Background="{DynamicResource AccentSoft}"
                        BorderBrush="{DynamicResource Border}"
                        BorderThickness="1">
                    <TextBlock Text="{Binding CountryCode}"
                               FontSize="8"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Accent}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <!-- Real PNG flag, clipped to the same 3px rounded rect.
                     Stretch=Uniform preserves aspect ratio (no warped
                     national symbols). Visibility flips to Collapsed
                     when FlagSource is null (DataTrigger below). -->
                <Border x:Name="FlagImageHost"
                        CornerRadius="3"
                        BorderBrush="#22000000"
                        BorderThickness="0.5"
                        ClipToBounds="True"
                        SnapsToDevicePixels="True">
                    <Image Source="{Binding FlagSource}"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>
            </Grid>

            <!-- Language name -->
            <TextBlock Text="{Binding Label}"
                       Margin="10,0,0,0"
                       FontSize="14.5"
                       FontWeight="Medium"
                       FontFamily="Segoe UI"
                       Foreground="{DynamicResource TextPrimary}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding HasFlag}" Value="False">
                <Setter TargetName="FlagImageHost" Property="Visibility" Value="Collapsed" />
            </DataTrigger>
            <DataTrigger Binding="{Binding HasFlag}" Value="True">
                <Setter TargetName="FlagFallback" Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <Style x:Key="VoiceLangComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <!-- Three stacked layers:
                         1) HoverFx — light hover tint, opacity animated 0↔1
                         2) SelectFx — soft-purple selection background, opacity flips to 1 when selected
                         3) Content — flag + label + checkmark
                         Layering means we can fade hover smoothly without
                         losing the selected highlight underneath. -->
                    <Grid x:Name="Root"
                          Margin="0,1"
                          MinHeight="{TemplateBinding MinHeight}"
                          SnapsToDevicePixels="True">

                        <Border x:Name="HoverFx"
                                CornerRadius="10"
                                Background="{DynamicResource BgHover}"
                                Opacity="0" />

                        <Border x:Name="SelectFx"
                                CornerRadius="10"
                                Background="{DynamicResource AccentSoft}"
                                Opacity="0" />

                        <Border Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left" />

                                <!-- Checkmark, visible only for the selected row -->
                                <Path x:Name="Check"
                                      Grid.Column="1"
                                      Margin="12,0,2,0"
                                      VerticalAlignment="Center"
                                      Width="13" Height="13"
                                      Stretch="Uniform"
                                      Data="M2 8 L6 12 L14 4"
                                      Stroke="{DynamicResource Accent}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed" />
                            </Grid>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Smooth fade for hover. IsHighlighted covers
                             both mouse-over and keyboard-arrow focus. -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverFx"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverFx"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.18" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!-- Selected: soft-purple bg + checkmark -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="SelectFx" Property="Opacity" Value="1" />
                            <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="VoiceLangComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Emoji" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource VoiceLangComboBoxItem}" />
        <Setter Property="ItemTemplate" Value="{StaticResource VoiceLangItemTemplate}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="MaxDropDownHeight" Value="380" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Invisible toggle button covers the whole control
                             so a click anywhere opens the popup. -->
                        <ToggleButton x:Name="DropToggle"
                                      Grid.ColumnSpan="2"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen,
                                                  RelativeSource={RelativeSource TemplatedParent},
                                                  Mode=TwoWay}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent" />
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!-- Selected pill content. Uses the same
                             VoiceLangItemTemplate so the flag + name
                             render exactly like the dropdown rows. -->
                        <ContentPresenter Grid.Column="0"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{StaticResource VoiceLangItemTemplate}" />

                        <!-- Chevron -->
                        <Path Grid.Column="1"
                              Margin="0,0,14,0"
                              VerticalAlignment="Center"
                              Width="10" Height="6"
                              Stretch="Uniform"
                              Data="M 0 0 L 5 5 L 10 0"
                              Stroke="{DynamicResource TextMuted}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              IsHitTestVisible="False" />

                        <!-- Popup with the list.
                             The outer Grid is intentionally larger than the
                             rounded Border (Margin=20) so the DropShadow has
                             empty transparent space to render into; without
                             that buffer the popup window clips the shadow at
                             the Border edge and produces grey square corners.
                             HorizontalOffset/VerticalOffset are set negative
                             to compensate for the Grid margin so the visible
                             pill still appears 8px below the trigger. -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Placement="Bottom"
                               PopupAnimation="Slide"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               HorizontalOffset="-20"
                               VerticalOffset="-12">
                            <Grid Margin="20">
                                <Grid.Background>
                                    <SolidColorBrush Color="Transparent" />
                                </Grid.Background>
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource BgSurface}"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="6"
                                        SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black"
                                                          Opacity="0.18"
                                                          ShadowDepth="4"
                                                          BlurRadius="20" />
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Background="Transparent">
                                        <StackPanel IsItemsHost="True" Background="Transparent" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         TRANSLATOR PAGE — premium glassmorphic styles
         ============================================================
         All styles below are scoped to the redesigned Translator
         page. The aim is a Raycast / Linear / Arc-style feel using
         only native WPF primitives:
           • white/translucent surfaces (no Win11 acrylic)
           • soft purple drop shadow for the "glow"
           • inline storyboards for swap rotation + toggle slide
           • zero external dependencies, fully theme-aware
         ============================================================ -->

    <!-- Glass card: white surface with a faint purple glow shadow.
         Reused for the language picker tiles, source/target panels,
         and the recent translations strip. -->
    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BgSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#6D4BFF"
                                  Opacity="0.09"
                                  BlurRadius="24"
                                  ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         Translator language picker — mirrors the Voice Box system
         ============================================================
         These 3 styles are a 1:1 copy of VoiceLangItemTemplate /
         VoiceLangComboBoxItem / VoiceLangComboBox, adapted to bind to
         LanguageCatalog.LanguageOption (Code, Name, Flag) instead of
         LangOption (Code, Label, CountryCode, FlagSource, HasFlag).
         The visual footprint — 20×14 flag tile, 44-px rows, 16-px
         wrapping Border with a soft shadow — is identical.
         ============================================================ -->

    <!-- Single-line row: real 22×16 PNG flag + Medium-weight language
         name + a right-aligned check mark for the selected row. Falls
         back to a 2-letter country-code pill when the PNG is missing. -->
    <DataTemplate x:Key="TranslatorLangItemTemplate">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Flag area: 22×16. Real PNG on top; soft-purple fallback
                 badge beneath so a missing asset still looks intentional. -->
            <Grid Grid.Column="0" Width="22" Height="16"
                  VerticalAlignment="Center"
                  SnapsToDevicePixels="True">
                <!-- Fallback pill (visible by default). -->
                <Border x:Name="FlagFallback"
                        CornerRadius="3"
                        Background="{DynamicResource AccentSoft}"
                        BorderBrush="{DynamicResource Border}"
                        BorderThickness="1">
                    <TextBlock Text="{Binding FallbackBadge}"
                               FontSize="8"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Accent}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <!-- Real PNG, clipped to rounded corners. -->
                <Border x:Name="FlagImageHost"
                        CornerRadius="3"
                        BorderBrush="#22000000"
                        BorderThickness="0.5"
                        ClipToBounds="True"
                        SnapsToDevicePixels="True">
                    <Image Source="{Binding FlagAssetPath}"
                           Stretch="UniformToFill"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>
            </Grid>

            <!-- Language name -->
            <TextBlock Grid.Column="1"
                       Text="{Binding Name}"
                       Margin="12,0,0,0"
                       FontSize="14"
                       FontWeight="Medium"
                       FontFamily="Segoe UI"
                       Foreground="{DynamicResource TextPrimary}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />

            <!-- Selected checkmark. Revealed by the ComboBoxItem
                 selection trigger via the attached bool on the parent. -->
            <TextBlock Grid.Column="2"
                       x:Name="SelectedCheck"
                       FontFamily="{DynamicResource IconFont}"
                       Text="&#xE73E;"
                       FontSize="12"
                       Foreground="{DynamicResource Accent}"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Visibility="Collapsed" />
        </Grid>

        <DataTemplate.Triggers>
            <!-- Hide the fallback when we have a real PNG, and vice versa. -->
            <DataTrigger Binding="{Binding HasFlagAsset}" Value="False">
                <Setter TargetName="FlagImageHost" Property="Visibility" Value="Collapsed" />
            </DataTrigger>
            <DataTrigger Binding="{Binding HasFlagAsset}" Value="True">
                <Setter TargetName="FlagFallback" Property="Visibility" Value="Collapsed" />
            </DataTrigger>
            <!-- When this row is the selected one inside a ComboBoxItem,
                 reveal the checkmark. RelativeSource finds the ancestor
                 ComboBoxItem container. -->
            <DataTrigger
                Binding="{Binding RelativeSource={RelativeSource AncestorType=ComboBoxItem}, Path=IsSelected}"
                Value="True">
                <Setter TargetName="SelectedCheck" Property="Visibility" Value="Visible" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- Dropdown row — identical to VoiceLangComboBoxItem: 44px rows,
         fading hover tint, soft-purple selection pill + checkmark. -->
    <Style x:Key="TranslatorLangComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Grid x:Name="Root"
                          Margin="0,1"
                          MinHeight="{TemplateBinding MinHeight}"
                          SnapsToDevicePixels="True">

                        <Border x:Name="HoverFx"
                                CornerRadius="10"
                                Background="{DynamicResource BgHover}"
                                Opacity="0" />

                        <Border x:Name="SelectFx"
                                CornerRadius="10"
                                Background="{DynamicResource AccentSoft}"
                                Opacity="0" />

                        <Border Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left" />

                                <Path x:Name="Check"
                                      Grid.Column="1"
                                      Margin="12,0,2,0"
                                      VerticalAlignment="Center"
                                      Width="13" Height="13"
                                      Stretch="Uniform"
                                      Data="M2 8 L6 12 L14 4"
                                      Stroke="{DynamicResource Accent}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed" />
                            </Grid>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverFx"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverFx"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.18" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="SelectFx" Property="Opacity" Value="1" />
                            <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox — 44-px row, chevron on the right, shadowed popup.
         Structurally identical to VoiceLangComboBox, only swapping
         the ItemContainerStyle + ItemTemplate to the Translator ones. -->
    <Style x:Key="TranslatorLangComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Emoji" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource TranslatorLangComboBoxItem}" />
        <Setter Property="ItemTemplate" Value="{StaticResource TranslatorLangItemTemplate}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="MaxDropDownHeight" Value="380" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ToggleButton x:Name="DropToggle"
                                      Grid.ColumnSpan="2"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen,
                                                  RelativeSource={RelativeSource TemplatedParent},
                                                  Mode=TwoWay}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent" />
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <ContentPresenter Grid.Column="0"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{StaticResource TranslatorLangItemTemplate}" />

                        <Path Grid.Column="1"
                              Margin="0,0,14,0"
                              VerticalAlignment="Center"
                              Width="10" Height="6"
                              Stretch="Uniform"
                              Data="M 0 0 L 5 5 L 10 0"
                              Stroke="{DynamicResource TextMuted}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              IsHitTestVisible="False" />

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Placement="Bottom"
                               PopupAnimation="Slide"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               HorizontalOffset="-20"
                               VerticalOffset="-8">
                            <Grid Margin="20">
                                <Grid.Background>
                                    <SolidColorBrush Color="Transparent" />
                                </Grid.Background>
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource BgSurface}"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="6"
                                        SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000"
                                                          Opacity="0.18"
                                                          ShadowDepth="4"
                                                          BlurRadius="22" />
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Background="Transparent">
                                        <StackPanel IsItemsHost="True" Background="Transparent" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Circular swap-languages button. 180° rotate on click, soft
         accent-tinted background on hover. The drop shadow stays
         active to give the "floating glass" feel. -->
    <Style x:Key="GlowSwapButton" TargetType="Button">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="46" />
        <Setter Property="Background" Value="{DynamicResource BgSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        <Setter Property="ToolTip" Value="Swap languages" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="23"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#6D4BFF"
                                              Opacity="0.20"
                                              BlurRadius="18"
                                              ShadowDepth="0" />
                        </Border.Effect>
                        <TextBlock x:Name="Icon"
                                   FontFamily="{DynamicResource IconFont}"
                                   Text="&#xE895;"
                                   FontSize="16"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="IconRotate" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentSoft}" />
                        </Trigger>
                        <EventTrigger RoutedEvent="Click">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="IconRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="180"
                                                     Duration="0:0:0.30">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- iOS-style toggle pill rendered as a restyled CheckBox.
         Off state: grey track, knob left.
         On  state: accent track, knob slides right.
         A pair of full-pill Borders is used (Off + On with Opacity 0/1)
         so the theme brushes stay untouched and the colour transition
         can be tweened without ColorAnimation on shared resources. -->
    <Style x:Key="TogglePill" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="44" Height="24" Background="Transparent">
                        <Border x:Name="TrackOff"
                                CornerRadius="12"
                                Background="{DynamicResource Border}"
                                SnapsToDevicePixels="True" />
                        <Border x:Name="TrackOn"
                                CornerRadius="12"
                                Background="{DynamicResource Accent}"
                                Opacity="0"
                                SnapsToDevicePixels="True" />
                        <Ellipse x:Name="Knob"
                                 Width="18" Height="18"
                                 Fill="White"
                                 HorizontalAlignment="Left"
                                 Margin="3,0,0,0"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="Black"
                                                  Opacity="0.18"
                                                  BlurRadius="6"
                                                  ShadowDepth="1" />
                            </Ellipse.Effect>
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="KnobShift" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobShift"
                                                         Storyboard.TargetProperty="X"
                                                         To="20" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="TrackOn"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.18" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobShift"
                                                         Storyboard.TargetProperty="X"
                                                         To="0" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="TrackOn"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.18" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary "Translate" CTA. Same purple background as PrimaryButton
         plus a stronger DropShadow for the signature glow. -->
    <Style x:Key="TranslateCTA" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Padding" Value="18,9" />
        <Setter Property="MinWidth" Value="132" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#6D4BFF"
                                  Opacity="0.45"
                                  BlurRadius="18"
                                  ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         Translator chip button
         ============================================================
         Secondary action for the Translator page (From Mobile, Clear,
         Copy, Clear all). Rounded-rectangle (12-px corner) with an
         accent-soft background wash, 1-px subtle border that deepens
         on hover. Icon slot is a separate coloured badge so the chip
         reads as a proper control, not a plain button.
         ============================================================ -->
    <Style x:Key="TranslatorChipButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource BgSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Height" Value="34" />
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="Padding" Value="4,0,12,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentSoft}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentMid}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Small round icon badge used inside TranslatorChipButton. The
         Fill is set per-instance so each action can have its own colour
         (blue for From Mobile, red for Clear, green for Copy, …). -->
    <Style x:Key="TranslatorChipIconBadge" TargetType="Border">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ============================================================
         Play Store "Get it on" button
         ============================================================
         Pill-shaped rich CTA with a white Play badge on a dark glass
         background, just like the official Google Play Badge asset.
         Used in Mobile Sync to send the user to the mobile app's store
         listing so they can install the companion app. -->
    <Style x:Key="PlayStoreButton" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A1033" Offset="0" />
                    <GradientStop Color="#3A1F78" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            SnapsToDevicePixels="True"
                            Padding="4">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0"
                                              BlurRadius="14"
                                              Color="#5B3FD1"
                                              Opacity="0.35" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#241449" Offset="0" />
                                        <GradientStop Color="#4A2A92" Offset="1" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1A1033" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         ABOUT PAGE — premium button + card system
         ============================================================
         Three styles share the same accent palette as the rest of the
         app but get tighter heights, pill / 14-px corners, and a soft
         purple drop-shadow so the About page feels less utilitarian
         than Settings while still using only native WPF primitives.
         ============================================================ -->

    <!-- Primary CTA used by the single "Check for Updates" button in the
         About header. 40 px tall, 14-px corner, purple gradient, white
         label, soft purple glow, scale-down on press. -->
    <Style x:Key="AboutPrimaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{DynamicResource AccentGradient}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="156" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="14"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#6D4BFF"
                                              Opacity="0.40"
                                              BlurRadius="18"
                                              ShadowDepth="0" />
                        </Border.Effect>
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BdScale" />
                        </Border.RenderTransform>
                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#6D4BFF"
                                                      Opacity="0.55"
                                                      BlurRadius="22"
                                                      ShadowDepth="0" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.97" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.97" Duration="0:0:0.08" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.10" />
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.10" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Social button used in the developer profile card.
         Rounded rectangle (not pill), 36 px tall, 12-px corner radius.
         AccentSoft background, accent-tinted border, hover deepens
         color + thickens border for a tactile feel. -->
    <Style x:Key="AboutSocialPill" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="92" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentMid}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            <Setter TargetName="Bd" Property="BorderThickness" Value="1.5" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Feature card used in the 2×2 grid. White surface, 22-px corner,
         soft shadow that intensifies on hover so the card feels like
         it lifts. Padding = 18 so the inner StackPanel breathes. -->
    <Style x:Key="AboutFeatureCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BgSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#6D4BFF"
                                  Opacity="0.07"
                                  BlurRadius="18"
                                  ShadowDepth="0" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#6D4BFF"
                                          Opacity="0.20"
                                          BlurRadius="26"
                                          ShadowDepth="0" />
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================
         Translator language ComboBox (premium, glass + flag rows)
         ============================================================
         Fully custom ComboBox + ComboBoxItem template so the dropdown
         matches the rest of the translator aesthetic: rounded 14-px
         card, white glass surface, purple hover, flag + native name
         in each row. No default Windows chrome leaks through.
         ============================================================ -->

    <!-- 22x16 flag image. Cropped to rounded corners via a clip. -->
    <Style x:Key="LanguageFlagImage" TargetType="Image">
        <Setter Property="Width"  Value="22" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Stretch" Value="UniformToFill" />
        <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- Each dropdown row. Flag + text + selected check. -->
    <Style x:Key="LanguageComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Height" Value="48" />
        <Setter Property="Padding" Value="18,0,14,0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="0">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentSoft}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentSoft}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- The selected-field "button" shown when the combo is closed. -->
    <ControlTemplate x:Key="LanguageComboToggleButton" TargetType="ToggleButton">
        <Border x:Name="Bd"
                Background="{DynamicResource BgSurface}"
                BorderBrush="{DynamicResource Border}"
                BorderThickness="1"
                CornerRadius="12"
                SnapsToDevicePixels="True"
                Padding="14,0,12,0"
                MinHeight="44">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ContentPresenter Grid.Column="0"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Stretch" />
                <TextBlock Grid.Column="1"
                           FontFamily="{DynamicResource IconFont}"
                           Text="&#xE70D;"
                           FontSize="10"
                           Foreground="{DynamicResource TextMuted}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- The ComboBox itself. Custom template gives us a glass popup,
         rounded corners, and no Windows chrome. -->
    <Style x:Key="LanguageComboBox" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource LanguageComboBoxItem}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- Display area: glass card with a chevron -->
                        <ToggleButton x:Name="ToggleButton"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      ClickMode="Press"
                                      Template="{StaticResource LanguageComboToggleButton}"
                                      HorizontalContentAlignment="Stretch">
                            <!-- Content: flag + text. Binding to the ComboBox's
                                 SelectedItem via ContentPresenter uses the
                                 SelectionBoxItemTemplate set below. -->
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch" />
                        </ToggleButton>

                        <!-- Dropdown popup -->
                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade"
                               VerticalOffset="4">
                            <Border Background="{DynamicResource BgSurface}"
                                    BorderBrush="{DynamicResource Border}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    SnapsToDevicePixels="True"
                                    Margin="8">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black"
                                                      Opacity="0.15"
                                                      BlurRadius="18"
                                                      ShadowDepth="0" />
                                </Border.Effect>
                                <Border CornerRadius="14"
                                        ClipToBounds="True"
                                        Background="Transparent">
                                    <ScrollViewer Margin="0,6,0,6"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


</ResourceDictionary>
