<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         LIGHT THEME
         All brush keys here MUST match those in Colors.Dark.xaml so
         DynamicResource lookups switch correctly at runtime.
         ============================================================ -->

    <Color x:Key="BgBaseColor">#F4F5FA</Color>
    <Color x:Key="BgSurfaceColor">#FFFFFF</Color>
    <Color x:Key="BgElevatedColor">#F8F9FC</Color>
    <Color x:Key="BgHoverColor">#EEF0F6</Color>
    <Color x:Key="BorderColor">#E3E6EE</Color>
    <Color x:Key="BorderStrongColor">#C9CEDB</Color>

    <Color x:Key="TextPrimaryColor">#0F172A</Color>
    <Color x:Key="TextSecondaryColor">#4B5567</Color>
    <Color x:Key="TextMutedColor">#7B8597</Color>

    <Color x:Key="AccentColor">#6D4BFF</Color>
    <Color x:Key="AccentHoverColor">#5E3CF0</Color>
    <Color x:Key="AccentPressedColor">#4F2EE0</Color>
    <Color x:Key="AccentSoftColor">#EBE6FF</Color>

    <Color x:Key="SuccessColor">#16A34A</Color>
    <Color x:Key="WarningColor">#D97706</Color>
    <Color x:Key="DangerColor">#DC2626</Color>

    <SolidColorBrush x:Key="BgBase" Color="#F4F5FA" />
    <SolidColorBrush x:Key="BgSurface" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BgElevated" Color="#F8F9FC" />
    <SolidColorBrush x:Key="BgHover" Color="#EEF0F6" />
    <SolidColorBrush x:Key="Border" Color="#E3E6EE" />
    <SolidColorBrush x:Key="BorderStrong" Color="#C9CEDB" />

    <SolidColorBrush x:Key="TextPrimary" Color="#0F172A" />
    <SolidColorBrush x:Key="TextSecondary" Color="#4B5567" />
    <SolidColorBrush x:Key="TextMuted" Color="#7B8597" />

    <SolidColorBrush x:Key="Accent" Color="#6D4BFF" />
    <SolidColorBrush x:Key="AccentHover" Color="#5E3CF0" />
    <SolidColorBrush x:Key="AccentPressed" Color="#4F2EE0" />
    <SolidColorBrush x:Key="AccentSoft" Color="#EBE6FF" />
    <!-- AccentMid: between AccentSoft and Accent. Used for the
         hover state of pill social buttons on the About page. -->
    <SolidColorBrush x:Key="AccentMid" Color="#D7CCFF" />

    <SolidColorBrush x:Key="Success" Color="#16A34A" />
    <SolidColorBrush x:Key="Warning" Color="#D97706" />
    <SolidColorBrush x:Key="Danger" Color="#DC2626" />

    <!-- Drawer-specific highlight brushes (light theme variants). -->
    <SolidColorBrush x:Key="NavHoverBg"    Color="#6D4BFF" Opacity="0.08" />
    <SolidColorBrush x:Key="NavSelectedBg" Color="#6D4BFF" Opacity="0.14" />

    <SolidColorBrush x:Key="QrCanvas" Color="#FFFFFF" />

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#7C5CFF" Offset="0" />
        <GradientStop Color="#4F2EE0" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeaderGlow" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#F6F4FF" Offset="0" />
        <GradientStop Color="#FFFFFF" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGlow" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0" />
        <GradientStop Color="#F7F8FC" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
