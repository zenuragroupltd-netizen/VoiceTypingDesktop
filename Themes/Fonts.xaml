<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Icon font. Segoe MDL2 Assets is guaranteed on Windows 10 and Windows 11
         and has all the glyphs we use. We avoid the comma-fallback syntax which
         WPF does not resolve reliably. -->
    <FontFamily x:Key="IconFont">Segoe MDL2 Assets</FontFamily>

</ResourceDictionary>
