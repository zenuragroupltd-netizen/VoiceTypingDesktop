<Window x:Class="VoiceTypingDesktop.Views.UpdateCheckErrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Check failed"
        Width="440" Height="290"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BgBase}"
        Foreground="{DynamicResource TextPrimary}"
        FontFamily="Segoe UI Variable, Segoe UI"
        WindowStyle="SingleBorderWindow">
    <Border Background="{DynamicResource BgBase}"
            BorderBrush="{DynamicResource Border}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Center"
                        HorizontalAlignment="Center" Margin="32">
                <Border Width="64" Height="64" CornerRadius="32"
                        Background="{DynamicResource Warning}"
                        HorizontalAlignment="Center">
                    <TextBlock FontFamily="{DynamicResource IconFont}"
                               Text="&#xE783;" FontSize="26"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Couldn't check for updates"
                           FontSize="17" FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,18,0,6" />
                <TextBlock x:Name="DetailText"
                           Text="Please check your internet connection and try again."
                           FontSize="12.5"
                           Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="340"
                           TextAlignment="Center" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{DynamicResource BgSurface}"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="0,1,0,0"
                    Padding="20,12">
                <Button HorizontalAlignment="Right"
                        Style="{StaticResource PrimaryButton}"
                        Padding="22,8"
                        Click="OkBtn_Click">
                    <TextBlock Text="OK" Foreground="White"
                               FontWeight="SemiBold" FontSize="12.5" />
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
