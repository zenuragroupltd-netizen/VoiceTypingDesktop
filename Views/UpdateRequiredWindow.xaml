<Window x:Class="VoiceTypingDesktop.Views.UpdateRequiredWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Required"
        Width="520" Height="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="{DynamicResource BgBase}"
        Foreground="{DynamicResource TextPrimary}"
        FontFamily="Segoe UI Variable, Segoe UI">

    <Border Background="{DynamicResource BgBase}"
            BorderBrush="{DynamicResource Border}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource BgSurface}"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="0,0,0,1"
                    Padding="24,20">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="12"
                            Background="{DynamicResource AccentGradient}">
                        <TextBlock FontFamily="{DynamicResource IconFont}"
                                   Text="&#xEBD3;" FontSize="20"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderTitle"
                                   Text="Update Required"
                                   FontSize="17" FontWeight="SemiBold" />
                        <TextBlock x:Name="HeaderSubtitle"
                                   Text="A new version is available. Please update to continue."
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Padding="24,18,24,10">
                <StackPanel>
                    <!-- Version row -->
                    <Border Background="{DynamicResource BgSurface}"
                            BorderBrush="{DynamicResource Border}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,10"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="YOUR VERSION"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMuted}" />
                                <TextBlock x:Name="CurrentVersionText"
                                           Text="1.0.0" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary}"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="&#xE72A;"
                                       FontFamily="{DynamicResource IconFont}"
                                       FontSize="16"
                                       Foreground="{DynamicResource Accent}"
                                       VerticalAlignment="Center"
                                       Margin="16,0,16,0" />
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="LATEST VERSION"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMuted}" />
                                <TextBlock x:Name="LatestVersionText"
                                           Text="1.1.0" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource Accent}"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Release notes -->
                    <TextBlock Text="WHAT'S NEW"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="4,0,0,6" />
                    <Border Background="{DynamicResource BgSurface}"
                            BorderBrush="{DynamicResource Border}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,12"
                            MinHeight="140">
                        <TextBlock x:Name="ReleaseNotesText"
                                   TextWrapping="Wrap"
                                   FontSize="12.5"
                                   LineHeight="20"
                                   Text="Release notes will appear here." />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer buttons -->
            <Border Grid.Row="2"
                    Background="{DynamicResource BgSurface}"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="0,1,0,0"
                    Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ExitBtn"
                            Grid.Column="0"
                            Style="{StaticResource DangerButton}"
                            Padding="14,8"
                            Click="ExitBtn_Click">
                        <TextBlock Text="Exit" FontSize="12.5" />
                    </Button>

                    <Button x:Name="LaterBtn"
                            Grid.Column="2"
                            Style="{StaticResource SecondaryButton}"
                            Padding="14,8"
                            Margin="0,0,8,0"
                            Visibility="Collapsed"
                            Click="LaterBtn_Click">
                        <TextBlock Text="Remind Me Later" FontSize="12.5" />
                    </Button>

                    <Button x:Name="DownloadBtn"
                            Grid.Column="3"
                            Style="{StaticResource PrimaryButton}"
                            Padding="16,8"
                            Click="DownloadBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{DynamicResource IconFont}"
                                       Text="&#xE896;" FontSize="13"
                                       Foreground="White"
                                       Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="Download Update"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="12.5"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
