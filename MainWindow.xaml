<Window x:Class="VoiceTypingDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Voice Typing Desktop"
        Icon="pack://application:,,,/Assets/app.ico"
        Height="760" Width="980"
        MinHeight="720" MinWidth="430"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBase}"
        Foreground="{DynamicResource TextPrimary}"
        FontFamily="Segoe UI Variable, Segoe UI"
        AllowsTransparency="False"
        WindowStyle="None"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SizeChanged="Window_SizeChanged">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BgBase}"
            BorderBrush="{DynamicResource Border}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
                <RowDefinition Height="32" />
            </Grid.RowDefinitions>

            <!-- ============================ TITLE BAR ============================ -->
            <Grid Grid.Row="0" Background="{DynamicResource HeaderGlow}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Margin="14,0,0,0" VerticalAlignment="Center">
                    <Border Width="22" Height="22" CornerRadius="6"
                            Background="{DynamicResource AccentGradient}">
                        <TextBlock FontFamily="{DynamicResource IconFont}"
                                   Text="&#xE720;" FontSize="12"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Voice Typing Desktop"
                               Margin="10,0,0,0"
                               FontSize="12.5"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Column="1" Text="" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Quick theme toggle (cycles System → Light → Dark) -->
                    <Button x:Name="ThemeBtn" Style="{StaticResource TitleBarButton}"
                            Click="ThemeBtn_Click" ToolTip="Toggle theme">
                        <TextBlock x:Name="ThemeGlyph"
                                   FontFamily="{DynamicResource IconFont}"
                                   Text="&#xE706;" FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}" />
                    </Button>
                    <!-- Pin (always on top) -->
                    <Button x:Name="PinBtn" Style="{StaticResource TitleBarButton}"
                            Click="PinBtn_Click" ToolTip="Pin on top (always on top)">
                        <TextBlock x:Name="PinGlyph"
                                   FontFamily="{DynamicResource IconFont}"
                                   Text="&#xE718;" FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}" />
                    </Button>
                    <Button Style="{StaticResource TitleBarButton}"
                            Click="MinBtn_Click" ToolTip="Minimize">
                        <TextBlock FontFamily="{DynamicResource IconFont}"
                                   Text="&#xE921;" FontSize="10" />
                    </Button>
                    <Button Style="{StaticResource TitleBarButton}"
                            Click="MaxBtn_Click" ToolTip="Maximize">
                        <TextBlock x:Name="MaxGlyph"
                                   FontFamily="{DynamicResource IconFont}"
                                   Text="&#xE922;" FontSize="10" />
                    </Button>
                    <Button Style="{StaticResource TitleBarCloseButton}"
                            Click="CloseBtn_Click" ToolTip="Close">
                        <TextBlock FontFamily="{DynamicResource IconFont}"
                                   Text="&#xE8BB;" FontSize="10" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ============================ BODY ============================ -->
            <Grid Grid.Row="1">

                <!-- Pages live underneath; the floating drawer overlays it.
                     The left margin clears the sidebar's footprint
                     (8px left margin + 52px sidebar width = 60px). -->
                <Grid Margin="60,0,0,0" Background="{DynamicResource BgBase}">

                    <!-- ============================================================
                         PAGE: MOBILE SYNC
                         Top:    collapsible pairing card (compact header + QR detail)
                         Bottom: history card filling the rest of the page
                         ============================================================ -->
                    <Grid x:Name="PageMobileSync" Margin="20,18,20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Page title -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Mobile Sync"
                                       FontSize="19" FontWeight="SemiBold" />
                            <TextBlock Text="Pair your phone and stream voice text in realtime."
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- Collapsible pairing card -->
                        <Border Grid.Row="1" Style="{StaticResource GlowCard}"
                                Padding="0" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Always-visible compact header (the entire row toggles expansion) -->
                                <Button x:Name="PairingHeaderBtn"
                                        Grid.Row="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Cursor="Hand"
                                        Click="PairingHeaderBtn_Click"
                                        HorizontalContentAlignment="Stretch">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="12">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>

                                    <Grid Margin="14,12,12,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Accent avatar -->
                                        <Border Grid.Column="0"
                                                Width="36" Height="36" CornerRadius="9"
                                                Background="{DynamicResource AccentGradient}">
                                            <TextBlock FontFamily="{DynamicResource IconFont}"
                                                       Text="&#xE8CE;" FontSize="16"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Pair code -->
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="PAIR CODE"
                                                       FontSize="9.5" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMuted}" />
                                            <TextBlock x:Name="PairCodeText"
                                                       Text="------"
                                                       FontSize="20" FontWeight="Bold"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       Margin="0,1,0,0" />
                                        </StackPanel>

                                        <!-- Status pill -->
                                        <Border Grid.Column="3"
                                                Background="{DynamicResource BgHover}"
                                                CornerRadius="999"
                                                Padding="10,5"
                                                VerticalAlignment="Center"
                                                Margin="8,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse x:Name="SyncDot"
                                                         Width="8" Height="8"
                                                         Fill="{DynamicResource Warning}"
                                                         VerticalAlignment="Center" />
                                                <TextBlock x:Name="MobileSyncStatusText"
                                                           Text="Starting..."
                                                           Margin="7,0,0,0"
                                                           FontSize="11.5"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>

                                        <!-- Chevron -->
                                        <Border Grid.Column="4"
                                                Width="30" Height="30" CornerRadius="8"
                                                Background="Transparent"
                                                VerticalAlignment="Center">
                                            <TextBlock x:Name="PairChevron"
                                                       FontFamily="{DynamicResource IconFont}"
                                                       Text="&#xE70E;"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Button>

                                <!-- Expandable detail panel -->
                                <Border x:Name="PairingDetail"
                                        Grid.Row="1"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="0,1,0,0"
                                        Padding="16,14,16,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- QR code on the left -->
                                        <Border Grid.Column="0"
                                                Background="{DynamicResource QrCanvas}"
                                                BorderBrush="{DynamicResource Border}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="8">
                                            <Grid Width="160" Height="160">
                                                <TextBlock x:Name="QrPlaceholder"
                                                           Text="(generating...)"
                                                           Foreground="#888"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                                <Image x:Name="QrImage" Stretch="Uniform" />
                                            </Grid>
                                        </Border>

                                        <!-- Right-side info -->
                                        <StackPanel Grid.Column="1" Margin="16,0,0,0"
                                                    VerticalAlignment="Center">

                                            <!-- App install buttons row -->
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,14">
                                                <!-- Play Store CTA -->
                                                <Button Style="{StaticResource PlayStoreButton}"
                                                        Click="OpenPlayStore_Click"
                                                        ToolTip="Install from Google Play Store"
                                                        Margin="0,0,10,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0"
                                                                Width="34" Height="34"
                                                                CornerRadius="9"
                                                                Background="White"
                                                                VerticalAlignment="Center">
                                                            <Viewbox Width="20" Height="22"
                                                                     Stretch="Uniform"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center">
                                                                <Canvas Width="28.99" Height="31.99">
                                                                    <Path Fill="#EA4335"
                                                                          Data="M13.54 15.28 L0.12 29.34 A3.66 3.66 0 0 0 5.45 31.5 L20.55 22.9 Z" />
                                                                    <Path Fill="#FBBC04"
                                                                          Data="M27.11 12.89 L20.58 9.15 L13.23 15.60 L20.61 22.88 L27.09 19.18 A3.54 3.54 0 0 0 28.59 14.39 A3.62 3.62 0 0 0 27.09 12.89 Z" />
                                                                    <Path Fill="#4285F4"
                                                                          Data="M0.12 2.66 A3.57 3.57 0 0 0 0 3.58 L0 28.42 A3.57 3.57 0 0 0 0.12 29.34 L14 15.64 Z" />
                                                                    <Path Fill="#34A853"
                                                                          Data="M13.64 16 L20.58 9.15 L5.5 0.51 A3.73 3.73 0 0 0 3.63 0 A3.64 3.64 0 0 0 0.12 2.65 Z" />
                                                                </Canvas>
                                                            </Viewbox>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Margin="10,0,12,0"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="GET IT ON"
                                                                       FontSize="8.5"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#BDB8FF" />
                                                            <TextBlock Text="Google Play"
                                                                       FontSize="13.5"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"
                                                                       Margin="0,-1,0,0" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>

                                                <!-- Direct APK download CTA -->
                                                <Button Style="{StaticResource PlayStoreButton}"
                                                        Click="DownloadApk_Click"
                                                        ToolTip="Download APK directly (no Play Store needed)">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <!-- Download arrow icon badge -->
                                                        <Border Grid.Column="0"
                                                                Width="34" Height="34"
                                                                CornerRadius="9"
                                                                Background="White"
                                                                VerticalAlignment="Center">
                                                            <Viewbox Width="18" Height="18"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center">
                                                                <Canvas Width="24" Height="24">
                                                                    <!-- Android robot head (simplified) -->
                                                                    <Path Fill="#3DDC84"
                                                                          Data="M6,10 L6,17 C6,17.55 6.45,18 7,18 L8,18 L8,21 C8,21.55 8.45,22 9,22 C9.55,22 10,21.55 10,21 L10,18 L14,18 L14,21 C14,21.55 14.45,22 15,22 C15.55,22 16,21.55 16,21 L16,18 L17,18 C17.55,18 18,17.55 18,17 L18,10 Z" />
                                                                    <Path Fill="#3DDC84"
                                                                          Data="M4,10 C3.45,10 3,10.45 3,11 L3,15 C3,15.55 3.45,16 4,16 C4.55,16 5,15.55 5,15 L5,11 C5,10.45 4.55,10 4,10 Z M20,10 C19.45,10 19,10.45 19,11 L19,15 C19,15.55 19.45,16 20,16 C20.55,16 21,15.55 21,15 L21,11 C21,10.45 20.55,10 20,10 Z" />
                                                                    <Path Fill="#3DDC84"
                                                                          Data="M7,4.5 L7,9 L17,9 L17,4.5 C17,2.57 15.43,1 13.5,1 L10.5,1 C8.57,1 7,2.57 7,4.5 Z" />
                                                                    <Ellipse Canvas.Left="9" Canvas.Top="3" Width="2" Height="2" Fill="White" />
                                                                    <Ellipse Canvas.Left="13" Canvas.Top="3" Width="2" Height="2" Fill="White" />
                                                                </Canvas>
                                                            </Viewbox>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Margin="10,0,12,0"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="DOWNLOAD"
                                                                       FontSize="8.5"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#BDB8FF" />
                                                            <TextBlock Text="APK File"
                                                                       FontSize="13.5"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"
                                                                       Margin="0,-1,0,0" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>
                                            </StackPanel>

                                            <TextBlock Text="HOW TO PAIR"
                                                       FontSize="9.5" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMuted}" />
                                            <TextBlock Text="Open the Voice Typing app on your phone and scan this QR code, or type the pair code shown above."
                                                       TextWrapping="Wrap" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       Margin="0,4,0,12" />

                                            <TextBlock Text="DEVICE ID"
                                                       FontSize="9.5" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMuted}" />
                                            <TextBlock x:Name="DeviceIdText" Text="—"
                                                       FontSize="11" TextWrapping="Wrap"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       Margin="0,2,0,10" />

                                            <!-- Live diagnostic line: shows poll count + last text time -->
                                            <TextBlock x:Name="SyncDiagText"
                                                       Text=""
                                                       FontSize="10.5"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,10" />

                                            <!-- Re-pair button: forces a new session lookup -->
                                            <Button x:Name="RepairButton"
                                                    Style="{StaticResource SecondaryButton}"
                                                    HorizontalAlignment="Left"
                                                    Padding="10,6"
                                                    Click="RepairButton_Click"
                                                    ToolTip="Forget the current session and re-pair from your phone.">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="{DynamicResource IconFont}"
                                                               FontSize="11" Text="&#xE72C;"
                                                               Margin="0,0,6,0"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="Re-pair" FontSize="11.5"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- History card (fills remaining space) -->
                        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="16,14,16,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="History" FontSize="14"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="All texts received from mobile, saved locally."
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="11" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Style="{StaticResource Badge}"
                                            VerticalAlignment="Center">
                                        <TextBlock x:Name="ReceivedCountText"
                                                   Text="0 items" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}" />
                                    </Border>
                                </Grid>

                                <!-- Body: the ListBox owns its own ScrollViewer. We do NOT
                                     wrap it in an outer ScrollViewer (that breaks mouse-wheel
                                     scrolling and item virtualization). EmptyState overlays
                                     when the list is empty. -->
                                <Grid Grid.Row="1" Margin="8,0,8,0">
                                    <StackPanel x:Name="EmptyState"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Margin="0,32,0,32">
                                        <Border Width="52" Height="52" CornerRadius="26"
                                                Background="{DynamicResource BgHover}"
                                                HorizontalAlignment="Center">
                                            <TextBlock FontFamily="{DynamicResource IconFont}"
                                                       FontSize="22"
                                                       Text="&#xE8EA;"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="No texts yet" FontSize="13.5"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,10,0,2" />
                                        <TextBlock Text="Pair your mobile and start talking."
                                                   Foreground="{DynamicResource TextMuted}"
                                                   HorizontalAlignment="Center" FontSize="11.5" />
                                    </StackPanel>

                                    <ListBox x:Name="ReceivedTextsList"
                                             Style="{StaticResource FlatListBox}"
                                             ItemContainerStyle="{StaticResource FlatListBoxItem}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ScrollViewer.CanContentScroll="True"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource BgElevated}"
                                                            BorderBrush="{DynamicResource Border}"
                                                            BorderThickness="1" CornerRadius="10"
                                                            Padding="12,10" Margin="4,3">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="{Binding Text}"
                                                                           TextWrapping="Wrap" FontSize="12.5" />
                                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                                    <TextBlock FontFamily="{DynamicResource IconFont}"
                                                                               FontSize="10" Text="&#xE823;"
                                                                               Foreground="{DynamicResource TextMuted}"
                                                                               Margin="0,0,4,0"
                                                                               VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding CreatedAtDisplay}"
                                                                               Foreground="{DynamicResource TextMuted}"
                                                                               FontSize="10.5" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1"
                                                                        Orientation="Vertical"
                                                                        Margin="10,0,0,0"
                                                                        VerticalAlignment="Center">
                                                                <!-- Copy to clipboard -->
                                                                <Button Style="{StaticResource TranslatorChipButton}"
                                                                        MinWidth="88" Height="30"
                                                                        Padding="4,0,10,0"
                                                                        Margin="0,0,0,6"
                                                                        Tag="{Binding Text}"
                                                                        Click="ItemCopyButton_Click"
                                                                        ToolTip="Copy to clipboard">
                                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <Border Style="{StaticResource TranslatorChipIconBadge}"
                                                                                Width="20" Height="20"
                                                                                CornerRadius="6"
                                                                                Background="#22C55E">
                                                                            <TextBlock FontFamily="{DynamicResource IconFont}"
                                                                                       Text="&#xE8C8;" FontSize="10"
                                                                                       Foreground="White"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center" />
                                                                        </Border>
                                                                        <TextBlock Text="Copy" FontSize="11" VerticalAlignment="Center" />
                                                                    </StackPanel>
                                                                </Button>

                                                                <!-- Paste straight into the active app -->
                                                                <Button Style="{StaticResource TranslatorChipButton}"
                                                                        MinWidth="88" Height="30"
                                                                        Padding="4,0,10,0"
                                                                        Tag="{Binding Text}"
                                                                        Click="ItemPasteButton_Click"
                                                                        ToolTip="Paste into the last active app">
                                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <Border Style="{StaticResource TranslatorChipIconBadge}"
                                                                                Width="20" Height="20"
                                                                                CornerRadius="6"
                                                                                Background="#7C5CFF">
                                                                            <TextBlock FontFamily="{DynamicResource IconFont}"
                                                                                       Text="&#xE77F;" FontSize="10"
                                                                                       Foreground="White"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center" />
                                                                        </Border>
                                                                        <TextBlock Text="Paste" FontSize="11" VerticalAlignment="Center" />
                                                                    </StackPanel>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>

                                <!-- Action bar: refined buttons, right-aligned -->
                                <Border Grid.Row="2"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="0,1,0,0"
                                        Padding="14,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock FontFamily="{DynamicResource IconFont}"
                                                       Text="&#xE946;" FontSize="11"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,6,0" />
                                            <TextBlock Text="Saved locally on this PC"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button x:Name="ClearListButton"
                                                    Style="{StaticResource TranslatorChipButton}"
                                                    MinWidth="100"
                                                    Margin="0,0,8,0"
                                                    Click="ClearListButton_Click"
                                                    ToolTip="Clear local history (does not delete from Supabase)">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Style="{StaticResource TranslatorChipIconBadge}"
                                                            Background="#EF4444">
                                                        <TextBlock FontFamily="{DynamicResource IconFont}"
                                                                   Text="&#xE74D;" FontSize="11"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                    <TextBlock Text="Clear" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="CopyAllButton"
                                                    Style="{StaticResource TranslatorChipButton}"
                                                    MinWidth="112"
                                                    Margin="0"
                                                    Click="CopyAllButton_Click"
                                                    ToolTip="Copy every received message to clipboard">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Style="{StaticResource TranslatorChipIconBadge}"
                                                            Background="#22C55E">
                                                        <TextBlock FontFamily="{DynamicResource IconFont}"
                                                                   Text="&#xE8C8;" FontSize="11"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                    <TextBlock Text="Copy All" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ====================================================== PAGE: VOICE BOX (mic-centered) ====================================================== -->
                    <Grid x:Name="PageVoiceBox" Margin="20,18,20,16" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- ============ ROW 0 — HEADER ============
                             Three logical pieces, two grid rows:
                               Row 0 col 0: Title + subtitle
                               Row 0 col 1: "How it works" floating pill
                               Row 1 colspan 2: Language picker strip
                             ApplyResponsiveLayout (.xaml.cs) no longer moves
                             VbLangSection between rows — the picker now lives
                             permanently on its own row so the pill can keep
                             the top-right slot. The responsive code only
                             toggles HorizontalAlignment / Margin now. -->
                        <Grid x:Name="VbHeadingGrid" Grid.Row="0" Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Title block -->
                            <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Desktop Voice Box"
                                           FontSize="26"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="Click the mic, speak, and text appears in your active app."
                                           FontSize="13"
                                           Foreground="{DynamicResource TextSecondary}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <!-- "How it works" pill — glass-style floating
                                 button with a faint purple border, soft glow,
                                 and AccentSoft hover fill. Opens an in-app
                                 explainer popup. -->
                            <Button Grid.Row="0" Grid.Column="1"
                                    x:Name="VbHowItWorksBtn"
                                    Click="VbHowItWorks_Click"
                                    Cursor="Hand"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Margin="14,0,0,0"
                                    Background="{DynamicResource BgSurface}"
                                    BorderThickness="0"
                                    Padding="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="PillBd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{DynamicResource AccentMid}"
                                                BorderThickness="1.5"
                                                CornerRadius="999"
                                                Padding="14,8">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#7C5CFF"
                                                                  Opacity="0.18"
                                                                  ShadowDepth="0"
                                                                  BlurRadius="14" />
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal">
                                                <!-- Info glyph -->
                                                <Viewbox Width="14" Height="14"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,6,0">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 Z M13,17 L11,17 L11,11 L13,11 L13,17 Z M13,9 L11,9 L11,7 L13,7 L13,9 Z"
                                                              Fill="{DynamicResource Accent}" />
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock Text="How it works"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Accent}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="PillBd" Property="Background"
                                                        Value="{DynamicResource AccentSoft}" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="PillBd" Property="Background"
                                                        Value="{DynamicResource AccentMid}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Language picker — always lives in row 1
                                 (full-width strip beneath the title). The
                                 responsive code only tweaks alignment /
                                 margin now, not Grid.Row. -->
                            <StackPanel x:Name="VbLangSection"
                                        Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                        Margin="0,14,0,0"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center">
                                <TextBlock Text="RECOGNITION LANGUAGE"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMuted}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,14,0" />
                                <Border Background="{DynamicResource BgSurface}"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="2"
                                        MinWidth="260">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.06"
                                                          ShadowDepth="0" BlurRadius="14" />
                                    </Border.Effect>
                                    <ComboBox x:Name="VbLangCombo"
                                              Style="{StaticResource VoiceLangComboBox}"
                                              SelectionChanged="VbLang_SelectionChanged" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- ============ ROW 1 — HERO VOICE VISUALIZATION CARD ============
                             Premium glass card hosting:
                               • Background ambient glow (radial AccentSoft fade)
                               • Floating status pill (top)
                               • Symmetric waveform — 3 left bars + mic orb + 4 right bars
                                 (existing WaveBar1..WaveBar7 ScaleTransforms drive
                                  the equalizer storyboard from MainWindow.VoiceBox.cs)
                               • Listening label + verbose sub-status
                               • Live peak meter (functional diagnostic)
                               • Session info row (Model · Session · $Cost)

                             Existing x:Names preserved so all event handlers
                             and animation storyboards continue to work
                             without code changes:
                               VbPulseRing1/2 (+ scale transforms),
                               VbMicButton (+ Click=VbMic_Click),
                               VbWaveBars + WaveBar1..WaveBar7,
                               VbStatusText, VbSubStatusText, VbUsageText,
                               VbPeakMeterTrack, VbPeakMeterFill -->
                        <Border Grid.Row="1"
                                CornerRadius="28"
                                BorderBrush="{DynamicResource Border}"
                                BorderThickness="1"
                                ClipToBounds="True"
                                Padding="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#FFFFFF" Offset="0" />
                                    <GradientStop Color="#FAF8FF" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#7C5CFF" Opacity="0.10"
                                                  ShadowDepth="0" BlurRadius="36" />
                            </Border.Effect>

                            <Grid>
                                <!-- Background ambient radial glow — extremely
                                     subtle purple fog centered behind the mic.
                                     Cheap: just one ellipse with a radial
                                     gradient brush. No blur shaders, no
                                     particle engines. -->
                                <Ellipse Width="520" Height="520"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         IsHitTestVisible="False">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush GradientOrigin="0.5,0.5"
                                                             Center="0.5,0.5"
                                                             RadiusX="0.5" RadiusY="0.5">
                                            <GradientStop Color="#7C5CFF" Offset="0.0" />
                                            <GradientStop Color="#7C5CFF" Offset="0.35" />
                                            <GradientStop Color="#00FFFFFF" Offset="1.0" />
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                    <Ellipse.OpacityMask>
                                        <RadialGradientBrush>
                                            <GradientStop Color="Black" Offset="0" />
                                            <GradientStop Color="Transparent" Offset="1" />
                                        </RadialGradientBrush>
                                    </Ellipse.OpacityMask>
                                    <Ellipse.Opacity>0.06</Ellipse.Opacity>
                                </Ellipse>

                                <!-- Content grid: top status pill, center
                                     mic+waveform composition, bottom info -->
                                <Grid Margin="24,20,24,22">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" /> <!-- Status pill -->
                                        <RowDefinition Height="*" />     <!-- Mic + waveform -->
                                        <RowDefinition Height="Auto" /> <!-- Sub-status + meter + session info -->
                                    </Grid.RowDefinitions>

                                    <!-- ============ STATUS PILL ============
                                         A floating capsule with a colored dot
                                         + status text. The dot color follows
                                         VbStatusText.Foreground via binding,
                                         so all the existing color setters in
                                         StartMic / StopMic / OnDictation*
                                         automatically tint the dot too —
                                         no extra C# state machine needed. -->
                                    <Border Grid.Row="0"
                                            HorizontalAlignment="Center"
                                            Background="{DynamicResource BgSurface}"
                                            BorderBrush="{DynamicResource Border}"
                                            BorderThickness="1"
                                            CornerRadius="999"
                                            Padding="16,8">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000"
                                                              Opacity="0.07"
                                                              ShadowDepth="0"
                                                              BlurRadius="18" />
                                        </Border.Effect>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="VbStatusDot"
                                                     Width="8" Height="8"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,9,0"
                                                     Fill="{Binding ElementName=VbStatusText, Path=Foreground}">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect Color="#7C5CFF"
                                                                      Opacity="0.45"
                                                                      ShadowDepth="0"
                                                                      BlurRadius="6" />
                                                </Ellipse.Effect>
                                            </Ellipse>
                                            <TextBlock x:Name="VbStatusText"
                                                       Text="Tap the mic to start"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondary}" />
                                        </StackPanel>
                                    </Border>

                                    <!-- ============ MIC + SYMMETRIC WAVEFORM ============
                                         A horizontal composition: 3 left bars +
                                         mic orb (with two concentric pulse rings) +
                                         4 right bars. The ScaleTransform x:Names
                                         WaveBar1..WaveBar7 are preserved because
                                         StartWaveAnimation() in the code-behind
                                         iterates them by name. -->
                                    <Grid Grid.Row="1"
                                          x:Name="VbWaveBars"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="0,8,0,8">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">

                                            <!-- LEFT WAVEFORM (bars rise toward mic) -->
                                            <Border Width="5" Height="22" Margin="3,0" CornerRadius="3"
                                                    Background="{DynamicResource Accent}"
                                                    VerticalAlignment="Center"
                                                    RenderTransformOrigin="0.5,0.5"
                                                    Opacity="0.55">
                                                <Border.RenderTransform>
                                                    <ScaleTransform x:Name="WaveBar1" ScaleY="0.35" />
                                                </Border.RenderTransform>
                                            </Border>
                                            <Border Width="5" Height="42" Margin="3,0" CornerRadius="3"
                                                    Background="{DynamicResource Accent}"
                                                    VerticalAlignment="Center"
                                                    RenderTransformOrigin="0.5,0.5"
                                                    Opacity="0.7">
                                                <Border.RenderTransform>
                                                    <ScaleTransform x:Name="WaveBar2" ScaleY="0.5" />
                                                </Border.RenderTransform>
                                            </Border>
                                            <Border Width="5" Height="64" Margin="3,0" CornerRadius="3"
                                                    Background="{DynamicResource Accent}"
                                                    VerticalAlignment="Center"
                                                    RenderTransformOrigin="0.5,0.5"
                                                    Opacity="0.85">
                                                <Border.RenderTransform>
                                                    <ScaleTransform x:Name="WaveBar3" ScaleY="0.8" />
                                                </Border.RenderTransform>
                                            </Border>

                                            <!-- ============ MIC ORB ============
                                                 Two pulse rings behind a 150 px
                                                 gradient mic button. Reflection
                                                 highlight on top-left for the
                                                 "glass orb" feel. -->
                                            <Grid Margin="14,0">
                                                <!-- Outer pulse ring -->
                                                <Ellipse x:Name="VbPulseRing1"
                                                         Width="230" Height="230"
                                                         Fill="{DynamicResource AccentSoft}"
                                                         Opacity="0">
                                                    <Ellipse.RenderTransform>
                                                        <ScaleTransform x:Name="VbPulseRing1Scale"
                                                                        CenterX="115" CenterY="115"
                                                                        ScaleX="1" ScaleY="1" />
                                                    </Ellipse.RenderTransform>
                                                    <Ellipse.RenderTransformOrigin>
                                                        <Point X="0.5" Y="0.5" />
                                                    </Ellipse.RenderTransformOrigin>
                                                </Ellipse>
                                                <!-- Inner pulse ring -->
                                                <Ellipse x:Name="VbPulseRing2"
                                                         Width="180" Height="180"
                                                         Fill="{DynamicResource AccentSoft}"
                                                         Opacity="0">
                                                    <Ellipse.RenderTransform>
                                                        <ScaleTransform x:Name="VbPulseRing2Scale"
                                                                        CenterX="90" CenterY="90"
                                                                        ScaleX="1" ScaleY="1" />
                                                    </Ellipse.RenderTransform>
                                                    <Ellipse.RenderTransformOrigin>
                                                        <Point X="0.5" Y="0.5" />
                                                    </Ellipse.RenderTransformOrigin>
                                                </Ellipse>

                                                <!-- Mic button -->
                                                <Button x:Name="VbMicButton"
                                                        Width="150" Height="150"
                                                        Cursor="Hand"
                                                        Click="VbMic_Click"
                                                        BorderThickness="0"
                                                        Background="Transparent">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid x:Name="MicRoot"
                                                                  RenderTransformOrigin="0.5,0.5">
                                                                <Grid.RenderTransform>
                                                                    <ScaleTransform x:Name="MicScale" ScaleX="1" ScaleY="1" />
                                                                </Grid.RenderTransform>

                                                                <!-- Deeper gradient orb with outer glow -->
                                                                <Ellipse x:Name="MicBg">
                                                                    <Ellipse.Fill>
                                                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                            <GradientStop Color="#9A82FF" Offset="0" />
                                                                            <GradientStop Color="#7C5CFF" Offset="0.5" />
                                                                            <GradientStop Color="#4F2EE0" Offset="1" />
                                                                        </LinearGradientBrush>
                                                                    </Ellipse.Fill>
                                                                    <Ellipse.Effect>
                                                                        <DropShadowEffect ShadowDepth="0"
                                                                                          BlurRadius="36"
                                                                                          Color="#7C5CFF"
                                                                                          Opacity="0.55" />
                                                                    </Ellipse.Effect>
                                                                </Ellipse>

                                                                <!-- Glass reflection highlight (top-left arc) -->
                                                                <Ellipse Width="120" Height="120"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"
                                                                         Margin="-12,-22,0,0"
                                                                         IsHitTestVisible="False">
                                                                    <Ellipse.Fill>
                                                                        <RadialGradientBrush GradientOrigin="0.3,0.25"
                                                                                             Center="0.3,0.25"
                                                                                             RadiusX="0.55" RadiusY="0.55">
                                                                            <GradientStop Color="#80FFFFFF" Offset="0.0" />
                                                                            <GradientStop Color="#00FFFFFF" Offset="0.75" />
                                                                        </RadialGradientBrush>
                                                                    </Ellipse.Fill>
                                                                </Ellipse>

                                                                <!-- Mic glyph (white) -->
                                                                <Viewbox Width="64" Height="64"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="{StaticResource IconMic}"
                                                                              Fill="White" />
                                                                    </Canvas>
                                                                </Viewbox>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Trigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetName="MicScale"
                                                                                                 Storyboard.TargetProperty="ScaleX"
                                                                                                 To="1.04" Duration="0:0:0.18" />
                                                                                <DoubleAnimation Storyboard.TargetName="MicScale"
                                                                                                 Storyboard.TargetProperty="ScaleY"
                                                                                                 To="1.04" Duration="0:0:0.18" />
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </Trigger.EnterActions>
                                                                    <Trigger.ExitActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetName="MicScale"
                                                                                                 Storyboard.TargetProperty="ScaleX"
                                                                                                 To="1.0" Duration="0:0:0.18" />
                                                                                <DoubleAnimation Storyboard.TargetName="MicScale"
                                                                                                 Storyboard.TargetProperty="ScaleY"
                                                                                                 To="1.0" Duration="0:0:0.18" />
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </Trigger.ExitActions>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="MicBg" Property="Opacity" Value="0.9" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>

                                            <!-- RIGHT WAVEFORM (bars fall away from mic) -->
                                            <Border Width="5" Height="64" Margin="3,0" CornerRadius="3"
                                                    Background="{DynamicResource Accent}"
                                                    VerticalAlignment="Center"
                                                    RenderTransformOrigin="0.5,0.5"
                                                    Opacity="0.85">
                                                <Border.RenderTransform>
                                                    <ScaleTransform x:Name="WaveBar4" ScaleY="0.8" />
                                                </Border.RenderTransform>
                                            </Border>
                                            <Border Width="5" Height="52" Margin="3,0" CornerRadius="3"
                                                    Background="{DynamicResource Accent}"
                                                    VerticalAlignment="Center"
                                                    RenderTransformOrigin="0.5,0.5"
                                                    Opacity="0.75">
                                                <Border.RenderTransform>
                                                    <ScaleTransform x:Name="WaveBar5" ScaleY="0.6" />
                                                </Border.RenderTransform>
                                            </Border>
                                            <Border Width="5" Height="36" Margin="3,0" CornerRadius="3"
                                                    Background="{DynamicResource Accent}"
                                                    VerticalAlignment="Center"
                                                    RenderTransformOrigin="0.5,0.5"
                                                    Opacity="0.65">
                                                <Border.RenderTransform>
                                                    <ScaleTransform x:Name="WaveBar6" ScaleY="0.45" />
                                                </Border.RenderTransform>
                                            </Border>
                                            <Border Width="5" Height="22" Margin="3,0" CornerRadius="3"
                                                    Background="{DynamicResource Accent}"
                                                    VerticalAlignment="Center"
                                                    RenderTransformOrigin="0.5,0.5"
                                                    Opacity="0.55">
                                                <Border.RenderTransform>
                                                    <ScaleTransform x:Name="WaveBar7" ScaleY="0.35" />
                                                </Border.RenderTransform>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <!-- ============ BOTTOM STATUS STACK ============
                                         Verbose pipeline status, live peak meter,
                                         and session info row (Model · Time · Cost). -->
                                    <StackPanel Grid.Row="2"
                                                HorizontalAlignment="Center"
                                                Margin="0,4,0,0">

                                        <!-- Verbose sub-status (Sending Xs / Whisper returned: ...) -->
                                        <TextBlock x:Name="VbSubStatusText"
                                                   Text="Set your OpenAI API key below to enable Whisper"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="420" />

                                        <!-- Live peak meter — slim diagnostic
                                             bar driven by PeakLevelChanged. Hidden
                                             while mic is off (toggled in
                                             ShowPeakMeter/HidePeakMeter). -->
                                        <Border x:Name="VbPeakMeterTrack"
                                                Height="5"
                                                Width="220"
                                                CornerRadius="3"
                                                Background="{DynamicResource BgHover}"
                                                Visibility="Collapsed"
                                                Margin="0,10,0,0">
                                            <Border x:Name="VbPeakMeterFill"
                                                    CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    Width="0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#8A6CFF" Offset="0" />
                                                        <GradientStop Color="#5B3FD1" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Border>

                                        <!-- Session info row — Model · Session · Cost
                                             with small purple separator dots.
                                             VbUsageText is the legacy single-line
                                             usage string from RefreshUsageText();
                                             kept as-is for now (Phase 4 will split
                                             into three TextBlocks with proper
                                             separators bound to live data). -->
                                        <TextBlock x:Name="VbUsageText"
                                                   Text=""
                                                   FontSize="10.5"
                                                   FontFamily="Consolas"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,10,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- ============ ROW 2 — BOTTOM PANEL (Phase 2) ============
                             Two compact glass cards side-by-side. The mic
                             hotkey lives on the Settings page so this row
                             stays one panel tall and the mic remains
                             visible at MinHeight=720.

                               • LEFT  (3*) — VbApiKeyCard
                                 Lock-glyph label, status pill (state dot
                                 bound to status text foreground), premium
                                 rounded TextBox + gradient Save button,
                                 storage hint line.
                               • RIGHT (2*) — VbSmartTipCard
                                 Lightbulb header + rotating tip line. Hint
                                 text is set in code (RotateSmartTip in
                                 MainWindow.VoiceBox.cs) so we can swap tips
                                 without retouching XAML.

                             Existing x:Names preserved so all save / status
                             handlers continue to work without C# edits:
                               VbApiKeyBox, VbSaveKeyBtn, VbKeyStatusText. -->
                        <Grid x:Name="VbBottomPanelGrid"
                              Grid.Row="2"
                              Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <!-- ============ LEFT — API KEY CARD ============ -->
                            <Border x:Name="VbApiKeyCardBorder"
                                    Grid.Column="0"
                                    Style="{StaticResource VbApiKeyCard}">
                                <StackPanel>

                                    <!-- Top row: lock-glyph label + status pill -->
                                    <Grid Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Lock glyph + label -->
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Viewbox Width="14" Height="14"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,8,0">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M18,8 L17,8 L17,6 C17,3.24 14.76,1 12,1 C9.24,1 7,3.24 7,6 L7,8 L6,8 C4.9,8 4,8.9 4,10 L4,20 C4,21.1 4.9,22 6,22 L18,22 C19.1,22 20,21.1 20,20 L20,10 C20,8.9 19.1,8 18,8 Z M9,6 C9,4.34 10.34,3 12,3 C13.66,3 15,4.34 15,6 L15,8 L9,8 L9,6 Z M12,17 C10.9,17 10,16.1 10,15 C10,13.9 10.9,13 12,13 C13.1,13 14,13.9 14,15 C14,16.1 13.1,17 12,17 Z"
                                                          Fill="{DynamicResource Accent}" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Text="OpenAI API Key"
                                                       FontSize="12.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>

                                        <!-- Status pill — colored dot + label.
                                             Dot Fill is bound to VbKeyStatusText.Foreground
                                             so when UpdateKeyStatus() flips the text
                                             color (Success / Warning), the dot
                                             follows automatically. -->
                                        <Border Grid.Column="2"
                                                Background="{DynamicResource BgSurface}"
                                                BorderBrush="{DynamicResource Border}"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Padding="10,3">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,6,0"
                                                         Fill="{Binding ElementName=VbKeyStatusText, Path=Foreground}" />
                                                <TextBlock x:Name="VbKeyStatusText"
                                                           Text="Not set"
                                                           FontSize="10.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Warning}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Input + save button row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="VbApiKeyBox"
                                                 Grid.Column="0"
                                                 Style="{StaticResource VbApiKeyInput}" />
                                        <Button x:Name="VbSaveKeyBtn"
                                                Grid.Column="1"
                                                Style="{StaticResource VbApiKeySaveButton}"
                                                Margin="10,0,0,0"
                                                Click="VbSaveKey_Click"
                                                Content="Save" />
                                    </Grid>

                                    <!-- Storage / link hint -->
                                    <TextBlock FontSize="10.5"
                                               Foreground="{DynamicResource TextMuted}"
                                               Margin="2,8,0,0"
                                               TextTrimming="CharacterEllipsis">
                                        <Run Text="Stored locally on this PC. Get a key at " />
                                        <Hyperlink NavigateUri="https://platform.openai.com/api-keys"
                                                   RequestNavigate="VbApiKeyLink_RequestNavigate"
                                                   Foreground="{DynamicResource Accent}"
                                                   TextDecorations="None">platform.openai.com/api-keys</Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- ============ RIGHT — SMART TIP CARD ============ -->
                            <Border x:Name="VbSmartTipCardBorder"
                                    Grid.Column="1"
                                    Style="{StaticResource VbSmartTipCard}"
                                    Margin="12,0,0,0">
                                <StackPanel VerticalAlignment="Center">

                                    <!-- Header: lightbulb glyph + label -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <Viewbox Width="14" Height="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,7,0">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M9,21 C9,21.55 9.45,22 10,22 L14,22 C14.55,22 15,21.55 15,21 L15,20 L9,20 L9,21 Z M12,2 C8.14,2 5,5.14 5,9 C5,11.38 6.19,13.47 8,14.74 L8,17 C8,17.55 8.45,18 9,18 L15,18 C15.55,18 16,17.55 16,17 L16,14.74 C17.81,13.47 19,11.38 19,9 C19,5.14 15.86,2 12,2 Z"
                                                      Fill="{DynamicResource Accent}" />
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="SMART TIP"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Accent}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Rotating tip text. Default copy is a
                                         cost line; MainWindow.VoiceBox.cs
                                         picks a random tip on each open. -->
                                    <TextBlock x:Name="VbSmartTipText"
                                               Text="Whisper costs about $0.006 per minute. Pick the spoken language above for higher accuracy."
                                               FontSize="11.5"
                                               LineHeight="16"
                                               Foreground="{DynamicResource TextSecondary}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ====================================================== PAGE: TRANSLATOR (premium glassmorphism redesign) ======================================================
                         Layout:
                           Row 0  Heading: title + sparkle accent + subtitle
                                  on left; auto-translate TogglePill +
                                  provider pill on right.
                           Row 1  Two language picker GlassCards with an
                                  animated GlowSwapButton between them.
                           Row 2  Source / Target GlassCard panels with
                                  spacious glass editors and pill buttons
                                  (Translate = TranslateCTA glow).
                           Row 3  Recent translations GlassCard strip.

                         Two soft purple ambient ellipses behind everything
                         provide the page-level glow per the design brief. -->
                    <Grid x:Name="PageTranslator" Margin="20,18,20,16" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Ambient purple glow (top-right) -->
                        <Ellipse Grid.RowSpan="4"
                                 Width="380" Height="380"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,-140,-140,0"
                                 IsHitTestVisible="False"
                                 Opacity="0.40">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#7C5CFF" Offset="0" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <!-- Ambient purple glow (bottom-left) -->
                        <Ellipse Grid.RowSpan="4"
                                 Width="320" Height="320"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Bottom"
                                 Margin="-120,0,0,-120"
                                 IsHitTestVisible="False"
                                 Opacity="0.28">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#A78BFF" Offset="0" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- ============ HEADING ============
                             Title-only. Auto-translate is now on by
                             default and the provider pill is hidden,
                             so the right cluster is removed entirely. -->
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,16"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Translator"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                            <!-- Soft purple "sparkle" badge next to title -->
                            <Border CornerRadius="7"
                                    Padding="6,2"
                                    Margin="10,3,0,0"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource AccentSoft}">
                                <TextBlock FontFamily="{DynamicResource IconFont}"
                                           Text="&#xE945;"
                                           FontSize="11"
                                           Foreground="{DynamicResource Accent}" />
                            </Border>
                        </StackPanel>

                        <!-- ============ LANGUAGE PICKERS ============
                             Default (≥ CompactBreakpoint): horizontal —
                                 [ source ] [ swap ] [ target ]
                             Compact (< 650 px): the responsive layout
                             code in MainWindow.xaml.cs flips this Grid
                             to a vertical stack —
                                 [ source ]
                                 [ swap   ]
                                 [ target ]
                             by mutating Row/Column definitions and the
                             Grid.Row / Grid.Column attached props on the
                             three named children below. -->
                        <Grid x:Name="TranslatorLangGrid"
                              Grid.Row="1"
                              Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Source picker — identical wrapping Border
                                 to VbLangSection (Voice Box): white surface,
                                 1-px Border, 16-radius, 2-px Padding, soft
                                 black shadow. Keeps the x:Name so the
                                 responsive layout code can reposition it. -->
                            <Border x:Name="TranslatorSourceCard"
                                    Grid.Column="0"
                                    Background="{DynamicResource BgSurface}"
                                    BorderBrush="{DynamicResource Border}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="2"
                                    MinWidth="220">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.06"
                                                      ShadowDepth="0" BlurRadius="14" />
                                </Border.Effect>
                                <ComboBox x:Name="SourceLangCombo"
                                          Style="{StaticResource TranslatorLangComboBox}"
                                          SelectionChanged="Lang_SelectionChanged" />
                            </Border>

                            <Button x:Name="SwapLangsBtn"
                                    Grid.Column="1"
                                    Style="{StaticResource GlowSwapButton}"
                                    Margin="14,0,14,0"
                                    Click="SwapLangs_Click" />

                            <Border x:Name="TranslatorTargetCard"
                                    Grid.Column="2"
                                    Background="{DynamicResource BgSurface}"
                                    BorderBrush="{DynamicResource Border}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="2"
                                    MinWidth="220">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.06"
                                                      ShadowDepth="0" BlurRadius="14" />
                                </Border.Effect>
                                <ComboBox x:Name="TargetLangCombo"
                                          Style="{StaticResource TranslatorLangComboBox}"
                                          SelectionChanged="Lang_SelectionChanged" />
                            </Border>
                        </Grid>

                        <!-- ============ SOURCE / TARGET PANELS ============ -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Source pane -->
                            <Border Grid.Column="0"
                                    Style="{StaticResource GlassCard}"
                                    Margin="0,0,7,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Section header: SOURCE • LANGUAGE + char count -->
                                    <Grid Grid.Row="0" Margin="18,14,16,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   x:Name="SourceHeaderText"
                                                   Text="SOURCE"
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1"
                                                   x:Name="SourceCharCount"
                                                   Text="0 / 5000"
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMuted}" />
                                    </Grid>

                                    <!-- Glass editor -->
                                    <TextBox x:Name="SourceTextBox"
                                             Grid.Row="1"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             FontSize="14"
                                             Padding="4,2"
                                             MinHeight="170"
                                             Margin="14,4,12,8"
                                             CaretBrush="{DynamicResource Accent}"
                                             SelectionBrush="{DynamicResource AccentSoft}"
                                             Foreground="{DynamicResource TextPrimary}"
                                             TextChanged="SourceTextBox_TextChanged" />

                                    <!-- Source action bar -->
                                    <StackPanel Grid.Row="2"
                                                Orientation="Horizontal"
                                                Margin="14,4,14,14">
                                        <Button x:Name="PasteFromMobileBtn"
                                                Style="{StaticResource TranslatorChipButton}"
                                                Margin="0,0,8,0"
                                                Click="PasteFromMobile_Click"
                                                ToolTip="Fill source with the latest mobile message">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Style="{StaticResource TranslatorChipIconBadge}"
                                                        Background="#3B82F6">
                                                    <TextBlock FontFamily="{DynamicResource IconFont}"
                                                               Text="&#xE8EA;" FontSize="11"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Text="From Mobile" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="ClearSourceBtn"
                                                Style="{StaticResource TranslatorChipButton}"
                                                Click="ClearSource_Click"
                                                ToolTip="Clear the source text">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Style="{StaticResource TranslatorChipIconBadge}"
                                                        Background="#EF4444">
                                                    <TextBlock FontFamily="{DynamicResource IconFont}"
                                                               Text="&#xE74D;" FontSize="11"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Text="Clear" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Target pane -->
                            <Border Grid.Column="1"
                                    Style="{StaticResource GlassCard}"
                                    Margin="7,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="18,14,16,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   x:Name="TargetHeaderText"
                                                   Text="TRANSLATION"
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1"
                                                   x:Name="TranslationStatusText"
                                                   Text=""
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMuted}" />
                                    </Grid>

                                    <Grid Grid.Row="1">
                                        <TextBox x:Name="TargetTextBox"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 IsReadOnly="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 FontSize="14"
                                                 Padding="4,2"
                                                 MinHeight="170"
                                                 Margin="14,4,12,8"
                                                 CaretBrush="{DynamicResource Accent}"
                                                 SelectionBrush="{DynamicResource AccentSoft}"
                                                 Foreground="{DynamicResource TextPrimary}" />

                                        <!-- Loading shimmer overlay -->
                                        <Border x:Name="TranslateLoader"
                                                Background="{DynamicResource BgSurface}"
                                                Opacity="0.88"
                                                CornerRadius="14"
                                                Margin="6"
                                                Visibility="Collapsed">
                                            <StackPanel VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <TextBlock FontFamily="{DynamicResource IconFont}"
                                                           Text="&#xE895;"
                                                           FontSize="22"
                                                           Foreground="{DynamicResource Accent}"
                                                           HorizontalAlignment="Center">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform x:Name="LoaderRotate" CenterX="11" CenterY="11" />
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                                <TextBlock Text="Translating..."
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           FontSize="12"
                                                           Margin="0,8,0,0"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Target action bar: Copy (ghost) on the
                                         left, Translate (glow CTA) on the right. -->
                                    <Grid Grid.Row="2" Margin="14,4,14,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                x:Name="CopyTranslationBtn"
                                                Style="{StaticResource TranslatorChipButton}"
                                                Click="CopyTranslation_Click"
                                                ToolTip="Copy the translation">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Style="{StaticResource TranslatorChipIconBadge}"
                                                        Background="#22C55E">
                                                    <TextBlock FontFamily="{DynamicResource IconFont}"
                                                               Text="&#xE8C8;" FontSize="11"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Text="Copy" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="2"
                                                x:Name="TranslateBtn"
                                                Style="{StaticResource TranslateCTA}"
                                                Click="TranslateBtn_Click">
                                            <StackPanel Orientation="Horizontal" Margin="2,0">
                                                <TextBlock FontFamily="{DynamicResource IconFont}"
                                                           Text="&#xE945;"
                                                           FontSize="12"
                                                           Foreground="White"
                                                           Margin="0,0,7,0"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="Translate"
                                                           Foreground="White"
                                                           FontSize="12.5"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ============ RECENT TRANSLATIONS ============ -->
                        <Border Grid.Row="3"
                                Style="{StaticResource GlassCard}"
                                Margin="0,12,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="18,12,14,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               FontFamily="{DynamicResource IconFont}"
                                               Text="&#xE823;"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextMuted}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="1"
                                               Text="Recent translations"
                                               FontSize="12.5"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="2"
                                            x:Name="ClearTranslationHistoryBtn"
                                            Style="{StaticResource TranslatorChipButton}"
                                            MinWidth="100"
                                            Click="ClearTranslationHistory_Click"
                                            ToolTip="Remove all saved translations">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Style="{StaticResource TranslatorChipIconBadge}"
                                                    Background="#EF4444">
                                                <TextBlock FontFamily="{DynamicResource IconFont}"
                                                           Text="&#xE74D;" FontSize="11"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="Clear all" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <ListBox x:Name="TranslationHistoryList"
                                         Grid.Row="1"
                                         Style="{StaticResource FlatListBox}"
                                         MaxHeight="140"
                                         Margin="10,0,10,12">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource BgElevated}"
                                                    BorderBrush="{DynamicResource Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Padding="12,8"
                                                    Margin="4,3"
                                                    Cursor="Hand"
                                                    MouseLeftButtonUp="HistoryItem_Click"
                                                    Tag="{Binding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0"
                                                            Background="{DynamicResource AccentSoft}"
                                                            CornerRadius="999"
                                                            Padding="9,3"
                                                            Margin="0,0,10,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding LangPairDisplay}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource Accent}" />
                                                    </Border>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Preview}"
                                                               TextTrimming="CharacterEllipsis"
                                                               FontSize="12"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding CreatedAtDisplay}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource TextMuted}"
                                                               Margin="10,0,0,0"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ====================================================== PAGE: SETTINGS ====================================================== -->
                    <Grid x:Name="PageSettings" Margin="20,18,20,16" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Settings" FontSize="19" FontWeight="SemiBold" />
                            <TextBlock Text="Tune Voice Typing Desktop to your taste."
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" Margin="0,2,0,0" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <!-- Appearance -->
                                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock FontFamily="{DynamicResource IconFont}"
                                                       Text="&#xE790;" FontSize="14"
                                                       Foreground="{DynamicResource Accent}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0" />
                                            <TextBlock Text="Appearance" FontSize="14"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="Pick the theme. System follows your Windows setting."
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="11.5" Margin="0,0,0,14" />

                                        <TextBlock Text="THEME"
                                                   FontSize="9.5" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMuted}" />

                                        <Border Background="{DynamicResource BgElevated}"
                                                BorderBrush="{DynamicResource Border}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="3"
                                                HorizontalAlignment="Left"
                                                Margin="0,6,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton x:Name="ThemeSystemBtn"
                                                             Style="{StaticResource SegmentButton}"
                                                             GroupName="ThemePick"
                                                             Click="ThemeChoice_Click"
                                                             Tag="system">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontFamily="{DynamicResource IconFont}"
                                                                   Text="&#xE770;" FontSize="11"
                                                                   Margin="0,0,6,0"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Text="System" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </RadioButton>
                                                <RadioButton x:Name="ThemeLightBtn"
                                                             Style="{StaticResource SegmentButton}"
                                                             GroupName="ThemePick"
                                                             Click="ThemeChoice_Click"
                                                             Tag="light">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontFamily="{DynamicResource IconFont}"
                                                                   Text="&#xE706;" FontSize="11"
                                                                   Margin="0,0,6,0"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Text="Light" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </RadioButton>
                                                <RadioButton x:Name="ThemeDarkBtn"
                                                             Style="{StaticResource SegmentButton}"
                                                             GroupName="ThemePick"
                                                             Click="ThemeChoice_Click"
                                                             Tag="dark">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontFamily="{DynamicResource IconFont}"
                                                                   Text="&#xE708;" FontSize="11"
                                                                   Margin="0,0,6,0"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Text="Dark" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </RadioButton>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Window behaviour -->
                                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock FontFamily="{DynamicResource IconFont}"
                                                       Text="&#xE713;" FontSize="14"
                                                       Foreground="{DynamicResource Accent}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0" />
                                            <TextBlock Text="Window" FontSize="14"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="Control how the window behaves."
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="11.5" Margin="0,0,0,14" />

                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Always on top"
                                                           FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="Keep the window above other apps."
                                                           Foreground="{DynamicResource TextMuted}"
                                                           FontSize="11" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      x:Name="PinSettingCheck"
                                                      Click="PinSettingCheck_Click"
                                                      VerticalAlignment="Center" />
                                        </Grid>

                                    </StackPanel>
                                </Border>

                                <!-- Mic Hotkey.
                                     Moved here from the Voice Box page so
                                     the mic button stays prominent there.
                                     VbHotkeyBox / VbClearHotkeyBtn keep
                                     their existing names so the
                                     code-behind handlers (PreviewKeyDown,
                                     GotFocus, etc.) bind unchanged. -->
                                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock FontFamily="{DynamicResource IconFont}"
                                                       Text="&#xE765;" FontSize="14"
                                                       Foreground="{DynamicResource Accent}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0" />
                                            <TextBlock Text="Mic Hotkey" FontSize="14"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="Toggle the mic from anywhere in Windows with one key combo."
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="11.5" Margin="0,0,0,14" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="VbHotkeyBox"
                                                     Grid.Column="0"
                                                     MinHeight="36"
                                                     Padding="10,7"
                                                     FontSize="12.5"
                                                     IsReadOnly="True"
                                                     Cursor="Hand"
                                                     Text="Click here, then press keys"
                                                     GotFocus="VbHotkey_GotFocus"
                                                     LostFocus="VbHotkey_LostFocus"
                                                     PreviewKeyDown="VbHotkey_PreviewKeyDown" />
                                            <Button x:Name="VbClearHotkeyBtn"
                                                    Grid.Column="1"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Padding="12,6"
                                                    Margin="8,0,0,0"
                                                    Click="VbClearHotkey_Click">
                                                <TextBlock Text="Clear" FontSize="12" />
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- About -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock FontFamily="{DynamicResource IconFont}"
                                                       Text="&#xE946;" FontSize="14"
                                                       Foreground="{DynamicResource Accent}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0" />
                                            <TextBlock Text="About" FontSize="14"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="Voice Typing Desktop v1.0"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="12" Margin="0,8,0,0" />
                                        <TextBlock Text="Receive voice-typed text from your phone, instantly."
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="11.5" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ====================================================== PAGE: ABOUT (premium redesign)
                         ======================================================
                         • Single Check-for-Updates button (header only).
                         • App Hero card: light-purple gradient + soft glow.
                         • Profile card: 82px circular avatar with purple
                           ring; falls back to "MI" initials if the PNG is
                           missing (handled by AbtProfileImage_ImageFailed).
                         • 4 feature cards in a 2-col grid (TranslatorLangGrid
                           style stacking is applied in compact mode).
                         • Software Updates card has NO button. -->
                    <Grid x:Name="PageAbout" Margin="20,18,20,16" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- ============ HEADER ============
                             Left: title "About" + subtitle.
                             Right: ONE Check-for-Updates AboutPrimaryButton. -->
                        <Grid Grid.Row="0" Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="About"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock Text="App information"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12.5"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <Button x:Name="AbtCheckUpdatesBtn"
                                    Grid.Column="1"
                                    Style="{StaticResource AboutPrimaryButton}"
                                    VerticalAlignment="Center"
                                    Click="AbtCheckUpdates_Click">
                                <TextBlock x:Name="AbtCheckUpdatesBtnText"
                                           Text="Check for Updates" Foreground="White" />
                            </Button>
                        </Grid>

                        <!-- Body -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>

                                <!-- ===== APP HERO CARD =====
                                     Light-purple gradient surface with a 24-px
                                     corner and a soft accent shadow that sells
                                     the "premium hero" feel without any blur. -->
                                <Border CornerRadius="24"
                                        Padding="22"
                                        Margin="0,0,0,16"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F4EFFF" Offset="0" />
                                            <GradientStop Color="#E8DFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#6D4BFF"
                                                          Opacity="0.18"
                                                          BlurRadius="26"
                                                          ShadowDepth="0" />
                                    </Border.Effect>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- App icon: gradient tile with a mic glyph. -->
                                        <Border Grid.Column="0"
                                                Width="64" Height="64"
                                                CornerRadius="16"
                                                Background="{DynamicResource AccentGradient}"
                                                VerticalAlignment="Center">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#6D4BFF"
                                                                  Opacity="0.45"
                                                                  BlurRadius="16"
                                                                  ShadowDepth="0" />
                                            </Border.Effect>
                                            <TextBlock FontFamily="{DynamicResource IconFont}"
                                                       Text="&#xE720;"
                                                       FontSize="28"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    Margin="18,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Voice Typing Desktop"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="Voice typing and desktop dictation for every text field."
                                                       FontSize="12.5"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0" />
                                            <!-- Version badge removed.
                                                 The canonical place to read
                                                 the current version is the
                                                 "Software updates" card. -->
                                            <TextBlock x:Name="AbtVersionTextLarge"
                                                       Visibility="Collapsed" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- ===== DEVELOPER PROFILE CARD =====
                                     White card with the circular avatar
                                     (purple ring) on the left and the dev
                                     bio + social pills on the right. -->
                                <Border Style="{StaticResource AboutFeatureCard}"
                                        Padding="22"
                                        Margin="0,0,0,16">
                                    <Grid x:Name="AbtProfileGrid">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar tile: 82×82 circular image
                                             with a 2-px purple ring + soft
                                             glow. Layering, bottom-up:
                                               1. AccentSoft circle + "MI"
                                                  initials   (fallback)
                                               2. Image clipped to a circle
                                                  via Border.CornerRadius
                                                  + ClipToBounds. If the
                                                  PNG can't load, the
                                                  ImageFailed handler in
                                                  MainWindow.About.cs hides
                                                  the Image so the initials
                                                  underneath show through.
                                               3. 2-px accent ring on top. -->
                                        <Grid Grid.Column="0"
                                              x:Name="AbtAvatarBox"
                                              Width="82" Height="82"
                                              VerticalAlignment="Top">
                                            <Grid.Effect>
                                                <DropShadowEffect Color="#6D4BFF"
                                                                  Opacity="0.30"
                                                                  BlurRadius="16"
                                                                  ShadowDepth="0" />
                                            </Grid.Effect>

                                            <!-- Layer 1: soft purple fallback fill.
                                                 Stays visible only until the real
                                                 PNG finishes loading. -->
                                            <Ellipse Fill="{DynamicResource AccentSoft}" />
                                            <TextBlock x:Name="AbtProfileInitials"
                                                       Text="MI"
                                                       FontSize="26"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Accent}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />

                                            <!-- Layer 2: real photo as an ImageBrush
                                                 inside an Ellipse. Painting the
                                                 photo through an elliptical brush
                                                 gives us a truly round crop
                                                 (Border + ClipToBounds doesn't
                                                 clip child Images in WPF). -->
                                            <Ellipse x:Name="AbtProfileImageHost">
                                                <Ellipse.Fill>
                                                    <ImageBrush x:Name="AbtProfileImageBrush"
                                                                ImageSource="pack://application:,,,/Assets/profile.png"
                                                                Stretch="UniformToFill"
                                                                RenderOptions.BitmapScalingMode="HighQuality" />
                                                </Ellipse.Fill>
                                            </Ellipse>

                                            <!-- Hidden helper: only used by the
                                                 ImageFailed fallback path so we
                                                 can detect a missing asset and
                                                 keep showing the initials. -->
                                            <Image x:Name="AbtProfileImage"
                                                   Visibility="Collapsed"
                                                   Source="pack://application:,,,/Assets/profile.png"
                                                   ImageFailed="AbtProfileImage_ImageFailed" />

                                            <!-- Layer 3: crisp purple ring on top. -->
                                            <Ellipse Stroke="{DynamicResource Accent}"
                                                     StrokeThickness="2"
                                                     IsHitTestVisible="False" />
                                        </Grid>

                                        <StackPanel Grid.Column="1"
                                                    x:Name="AbtProfileTextPanel"
                                                    Margin="18,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Muinol Islam"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="Developer and digital tool creator"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       Margin="0,3,0,0" />
                                            <TextBlock Text="I build useful tools for productivity, automation, and digital workflows."
                                                       FontSize="12.5"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,10,0,0" />

                                            <!-- Social pill row: WrapPanel so
                                                 the pills flow to a second
                                                 line on narrow widths. -->
                                            <WrapPanel Orientation="Horizontal" Margin="0,14,0,0">
                                                <Button Style="{StaticResource AboutSocialPill}"
                                                        Margin="0,0,8,8"
                                                        Click="AbtWebsite_Click"
                                                        ToolTip="Open website">
                                                    <TextBlock Text="Website" />
                                                </Button>
                                                <Button Style="{StaticResource AboutSocialPill}"
                                                        Margin="0,0,8,8"
                                                        Click="AbtYouTube_Click"
                                                        ToolTip="YouTube channel">
                                                    <TextBlock Text="YouTube" />
                                                </Button>
                                                <Button Style="{StaticResource AboutSocialPill}"
                                                        Margin="0,0,8,8"
                                                        Click="AbtEmail_Click"
                                                        ToolTip="Send email">
                                                    <TextBlock Text="Email" />
                                                </Button>
                                                <Button Style="{StaticResource AboutSocialPill}"
                                                        Margin="0,0,8,8"
                                                        Click="AbtFacebook_Click"
                                                        ToolTip="Facebook page">
                                                    <TextBlock Text="Facebook" />
                                                </Button>
                                                <Button Style="{StaticResource AboutSocialPill}"
                                                        Margin="0,0,0,8"
                                                        Click="AbtTelegram_Click"
                                                        ToolTip="Telegram channel">
                                                    <TextBlock Text="Telegram" />
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- ===== FEATURE CARDS (2 × 2 grid) =====
                                     The grid is named so MainWindow.xaml.cs
                                     can flip it to a single-column stack
                                     when the window goes compact. -->
                                <Grid x:Name="AbtFeatureGrid" Margin="0,0,0,16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Card 1: Fast Dictation -->
                                    <Border x:Name="AbtFeatureCard1"
                                            Grid.Row="0" Grid.Column="0"
                                            Style="{StaticResource AboutFeatureCard}"
                                            Margin="0,0,8,8">
                                        <StackPanel>
                                            <Border Width="38" Height="38"
                                                    CornerRadius="11"
                                                    Background="{DynamicResource AccentSoft}"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,12">
                                                <TextBlock FontFamily="{DynamicResource IconFont}"
                                                           Text="&#xEC4A;" FontSize="15"
                                                           Foreground="{DynamicResource Accent}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="Fast Dictation"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="Convert speech to text quickly and send it anywhere."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Card 2: Desktop + Mobile Sync -->
                                    <Border x:Name="AbtFeatureCard2"
                                            Grid.Row="0" Grid.Column="1"
                                            Style="{StaticResource AboutFeatureCard}"
                                            Margin="8,0,0,8">
                                        <StackPanel>
                                            <Border Width="38" Height="38"
                                                    CornerRadius="11"
                                                    Background="{DynamicResource AccentSoft}"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,12">
                                                <TextBlock FontFamily="{DynamicResource IconFont}"
                                                           Text="&#xE8EA;" FontSize="15"
                                                           Foreground="{DynamicResource Accent}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="Desktop + Mobile Sync"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="Connect your phone and desktop for smooth cross-device typing."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Card 3: Multiple Languages -->
                                    <Border x:Name="AbtFeatureCard3"
                                            Grid.Row="1" Grid.Column="0"
                                            Style="{StaticResource AboutFeatureCard}"
                                            Margin="0,8,8,0">
                                        <StackPanel>
                                            <Border Width="38" Height="38"
                                                    CornerRadius="11"
                                                    Background="{DynamicResource AccentSoft}"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,12">
                                                <TextBlock FontFamily="{DynamicResource IconFont}"
                                                           Text="&#xE774;" FontSize="15"
                                                           Foreground="{DynamicResource Accent}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="Multiple Languages"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="Use Bengali, English, Hindi, Urdu and more."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Card 4: Whisper Support -->
                                    <Border x:Name="AbtFeatureCard4"
                                            Grid.Row="1" Grid.Column="1"
                                            Style="{StaticResource AboutFeatureCard}"
                                            Margin="8,8,0,0">
                                        <StackPanel>
                                            <Border Width="38" Height="38"
                                                    CornerRadius="11"
                                                    Background="{DynamicResource AccentSoft}"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,12">
                                                <TextBlock FontFamily="{DynamicResource IconFont}"
                                                           Text="&#xE720;" FontSize="15"
                                                           Foreground="{DynamicResource Accent}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="Whisper Support"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="Use OpenAI Whisper API for accurate transcription."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- ===== SOFTWARE UPDATES CARD =====
                                     Read-only status card. The "Check for
                                     Updates" button now lives only in the
                                     header — this card just shows state. -->
                                <Border Style="{StaticResource AboutFeatureCard}"
                                        Padding="22"
                                        Margin="0,0,0,4">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <Border Width="34" Height="34"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource AccentSoft}"
                                                    Margin="0,0,12,0">
                                                <TextBlock FontFamily="{DynamicResource IconFont}"
                                                           Text="&#xE777;"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource Accent}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Software Updates"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}" />
                                                <TextBlock Text="Stay up to date with the latest features and fixes."
                                                           FontSize="11.5"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                        </StackPanel>

                                        <Grid Margin="0,2,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="Current version"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="0" Grid.Column="1"
                                                       x:Name="AbtCurrentVersion"
                                                       Text="1.0.0"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       Margin="0,0,0,8" />

                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                       Text="Status"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       Margin="0,0,0,8" />
                                            <StackPanel Grid.Row="1" Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Margin="0,0,0,8">
                                                <Ellipse x:Name="AbtUpdateDot"
                                                         Width="8" Height="8"
                                                         Fill="{DynamicResource Success}"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,8,0" />
                                                <TextBlock x:Name="AbtUpdateStatus"
                                                           Text="Up to date"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Success}" />
                                            </StackPanel>

                                            <TextBlock Grid.Row="2" Grid.Column="0"
                                                       Text="Last checked"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMuted}" />
                                            <TextBlock Grid.Row="2" Grid.Column="1"
                                                       x:Name="AbtLastChecked"
                                                       Text="Not checked yet"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- ====================================================== SIDEBAR (icon-only, fixed thin rail) ======================================================
                     NOTE: ClipToBounds removed and shadow opacity softened.
                     ClipToBounds=True caused WPF to render the DropShadow
                     against the rectangular bounds of the Border, leaking
                     grey square corners outside the rounded radius. The
                     CornerRadius alone correctly clips Background; child
                     content inside does not overflow into the corners. -->
                <Border x:Name="DrawerPanel"
                        Background="{DynamicResource BgSurface}"
                        BorderBrush="{DynamicResource Border}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Width="52"
                        Margin="8,12,0,12"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0"
                                          BlurRadius="20"
                                          Color="Black"
                                          Opacity="0.12" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Drawer header (removed — icon-only mode) -->
                        <TextBlock x:Name="DrawerLabel"
                                   Grid.Row="0"
                                   Visibility="Collapsed" />

                        <ListBox x:Name="NavList" Grid.Row="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FocusVisualStyle="{x:Null}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource NavListBoxItem}"
                                 SelectedIndex="0"
                                 SelectionChanged="NavList_SelectionChanged">
                            <!-- Mobile Sync -->
                            <ListBoxItem ToolTip="Mobile Sync">
                                <Viewbox Width="20" Height="20"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconMobileSync}"
                                          Style="{StaticResource NavIconPath}" />
                                </Viewbox>
                            </ListBoxItem>
                            <!-- Voice Box -->
                            <ListBoxItem ToolTip="Desktop Voice Box">
                                <Viewbox Width="20" Height="20"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconMic}"
                                          Style="{StaticResource NavIconPath}" />
                                </Viewbox>
                            </ListBoxItem>
                            <!-- Translator -->
                            <ListBoxItem ToolTip="Translator">
                                <Viewbox Width="20" Height="20"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconTranslate}"
                                          Style="{StaticResource NavIconPath}" />
                                </Viewbox>
                            </ListBoxItem>
                            <!-- Settings -->
                            <ListBoxItem ToolTip="Settings">
                                <Viewbox Width="20" Height="20"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconSettings}"
                                          Style="{StaticResource NavIconPath}" />
                                </Viewbox>
                            </ListBoxItem>
                            <!-- About -->
                            <ListBoxItem ToolTip="About">
                                <Viewbox Width="20" Height="20"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconInfo}"
                                          Style="{StaticResource NavIconPath}" />
                                </Viewbox>
                            </ListBoxItem>
                        </ListBox>

                        <!-- Social links + connection dot -->
                        <StackPanel Grid.Row="2" Margin="0,4,0,10"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom">
                            <!-- Connection dot -->
                            <Grid Width="36" Height="36"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,6">
                                <Ellipse Width="28" Height="28"
                                         Stroke="{DynamicResource Border}"
                                         StrokeThickness="1"
                                         Fill="Transparent"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
                                <Ellipse x:Name="ConnDotCollapsed"
                                         Width="10" Height="10"
                                         Fill="{DynamicResource TextMuted}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
                            </Grid>

                            <!-- Telegram (brand cyan) -->
                            <Button Style="{StaticResource IconButton}"
                                    Width="36" Height="36"
                                    Margin="0,2,0,2"
                                    ToolTip="Telegram Channel"
                                    Click="TelegramBtn_Click">
                                <Grid Width="30" Height="30">
                                    <!-- Circular brand background -->
                                    <Ellipse Width="28" Height="28"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                <GradientStop Color="#37BBFE" Offset="0" />
                                                <GradientStop Color="#2D96E3" Offset="1" />
                                            </LinearGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <!-- Fixed 24x24 canvas → Viewbox centres reliably -->
                                    <Viewbox Width="15" Height="15"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Stretch="Uniform">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="{StaticResource IconTelegram}"
                                                  Fill="White" />
                                        </Canvas>
                                    </Viewbox>
                                </Grid>
                            </Button>

                            <!-- WhatsApp (brand green) -->
                            <Button Style="{StaticResource IconButton}"
                                    Width="36" Height="36"
                                    Margin="0,2,0,0"
                                    ToolTip="WhatsApp"
                                    Click="WhatsAppBtn_Click">
                                <Grid Width="30" Height="30">
                                    <Ellipse Width="28" Height="28"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                <GradientStop Color="#25D366" Offset="0" />
                                                <GradientStop Color="#128C7E" Offset="1" />
                                            </LinearGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <Viewbox Width="15" Height="15"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Stretch="Uniform">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="{StaticResource IconWhatsApp}"
                                                  Fill="White" />
                                        </Canvas>
                                    </Viewbox>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ============ STATUS BAR (Phase 3) ============
                 A slim 32-px glass strip at the bottom of the shell.
                 Top edge uses a horizontal gradient border (purple left,
                 fading to transparent right) instead of a flat grey rule
                 so the bar reads as part of the premium shell. Host a
                 few compact pills on the right:

                   [StatusBarMicPill]   mic state (dot + label),
                                        driven by VoiceBox UpdateMicVisualState
                   [StatusBarModelPill] static "Whisper" model chip
                   [StatusBarVersion]   rounded version badge

                 Existing x:Names preserved so nothing breaks:
                   StatusBarText, PinStatusLabel.
                 New x:Names for the VoiceBox to update live:
                   StatusBarMicDot, StatusBarMicText. -->
            <Grid Grid.Row="2">
                <!-- Glass surface with gradient top divider. The Border
                     below holds the surface + shadow; a second Rectangle
                     is stacked on top edge to render the gradient rule. -->
                <Border Background="{DynamicResource BgSurface}" SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05"
                                          ShadowDepth="-1" BlurRadius="6"
                                          Direction="90" />
                    </Border.Effect>
                </Border>
                <!-- Gradient top rule (1 px tall, hard-snapped). -->
                <Rectangle Height="1" VerticalAlignment="Top" SnapsToDevicePixels="True">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#7C5CFF" Offset="0" />
                            <GradientStop Color="#D6CCFF" Offset="0.5" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.Opacity>0.55</Rectangle.Opacity>
                </Rectangle>

                <!-- Status bar content -->
                <Grid Margin="16,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- LEFT — page status text -->
                    <TextBlock x:Name="StatusBarText" Text="Ready"
                               Grid.Column="0" FontSize="11.5"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />

                    <!-- RIGHT — pills cluster -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <!-- Pin/top status — shown when "always on top" is active.
                             Kept text-only (no pill) because it's usually empty. -->
                        <TextBlock x:Name="PinStatusLabel" Text=""
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Accent}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0" />

                        <!-- Mic state pill — dot + label.
                             Default: "Mic: Idle" in TextMuted.
                             VoiceBox UpdateMicVisualState flips this to
                             "Mic: Listening" in red while the mic is on. -->
                        <Border x:Name="StatusBarMicPill"
                                Background="{DynamicResource BgHover}"
                                BorderBrush="{DynamicResource Border}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="10,2"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusBarMicDot"
                                         Width="7" Height="7"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0"
                                         Fill="{DynamicResource TextMuted}" />
                                <TextBlock x:Name="StatusBarMicText"
                                           Text="Mic: Idle"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Model chip — static "Whisper" pill with
                             a purple tint so it reads as a capability badge. -->
                        <Border Background="{DynamicResource AccentSoft}"
                                BorderBrush="{DynamicResource AccentMid}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="10,2"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="Whisper"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Accent}"
                                       VerticalAlignment="Center" />
                        </Border>

                        <!-- Version chip — neutral, ends the cluster. -->
                        <Border Background="{DynamicResource BgHover}"
                                BorderBrush="{DynamicResource Border}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="10,2"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="StatusBarVersion"
                                       Text="v1.0"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMuted}"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
